function Write-Log {
    param([string]$Message,[ValidateSet("INFO","WARN","ERROR","SUCCESS","DEBUG","SECTION")][string]$Level="INFO")
    $line = "[{0}] [{1}] {2}" -f (Get-Date -Format "yyyy-MM-dd HH:mm:ss"),$Level,$Message
    Add-Content -Path $LogFile -Value $line
    $c=@{INFO="Cyan";WARN="Yellow";ERROR="Red";SUCCESS="Green";DEBUG="DarkGray";SECTION="Magenta"}[$Level]
    Write-Host $line -ForegroundColor $c
}

# ── AUTH (with auto-refresh) ────────────────────────────────────────────────────
$Global:Token=$null; $Global:TokenExpiry=Get-Date
function Get-AuthToken {
    $body=@{grant_type="client_credentials";client_id=$ServiceUserId;client_secret=$ServiceUserSecret}
    $r=Invoke-RestMethod -Uri "$IdentityUrl/oauth2/platformtoken" -Method POST -Body $body `
        -ContentType "application/x-www-form-urlencoded" -ErrorAction Stop
    $Global:Token=$r.access_token
    $exp= if($r.expires_in){[int]$r.expires_in}else{900}
    $Global:TokenExpiry=(Get-Date).AddSeconds($exp-60)
    Write-Log "Token acquired (valid ~${exp}s)." SUCCESS
}
function Get-Headers {
    if((Get-Date) -ge $Global:TokenExpiry){ Write-Log "Refreshing token..." WARN; Get-AuthToken }
    return @{Authorization="Bearer $Global:Token";"Content-Type"="application/json"}
}

# ── RESILIENT GET ───────────────────────────────────────────────────────────────
function Invoke-ApiGet {
    param([string]$Uri)
    $a=0
    while($a -le $MaxRetries){
        $a++
        try { return Invoke-RestMethod -Uri $Uri -Method GET -Headers (Get-Headers) -ErrorAction Stop }
        catch {
            $s= if($_.Exception.Response){[int]$_.Exception.Response.StatusCode}else{0}
            $m=$_.Exception.Message
            if($s -in @(400,403,404)){ Write-Log "GET $Uri -> $s $m (no retry)" ERROR; return $null }
            if($s -eq 401){ Write-Log "401 - refreshing token" WARN; Get-AuthToken; continue }
            if($a -le $MaxRetries){
                $w= if($s -eq 429){$RetryWaitSeconds*$a}else{$RetryWaitSeconds}
                Write-Log "GET $Uri -> $s $m (retry $a in ${w}s)" WARN; Start-Sleep -Seconds $w
            } else { Write-Log "GET $Uri -> $s $m (exhausted)" ERROR; return $null }
        }
    }
    return $null
}

function Get-AllPaged {
    param([string]$BaseUri,[string]$ValueProp="value")
    $all=@(); $off=0
    do {
        $sep= if($BaseUri -match '\?'){'&'}else{'?'}
        $resp=Invoke-ApiGet -Uri "$BaseUri${sep}limit=$PageLimit&offset=$off"
        if(-not $resp){break}
        $batch=$resp.$ValueProp
        if(-not $batch){break}
        $all+=$batch; $off+=$PageLimit
        Write-Log "  ...$($all.Count) records" DEBUG
    } while($batch.Count -eq $PageLimit)
    return $all
}

# ── HELPERS ──────────────────────────────────────────────────────────────────────
function ConvertFrom-Unix { param($v)
    if($null -eq $v -or $v -eq 0 -or "$v" -eq ""){ return $null }
    try { return [DateTimeOffset]::FromUnixTimeSeconds([long]$v).LocalDateTime } catch { return $null }
}
# CyberArk's Safes API returns lastModificationTime in Unix MICROSECONDS
# (16 digits), unlike creationTime which is seconds - convert accordingly.
function ConvertFrom-UnixMicro { param($v)
    if($null -eq $v -or $v -eq 0 -or "$v" -eq ""){ return $null }
    try { return [DateTimeOffset]::FromUnixTimeMilliseconds([long]([long]$v / 1000)).LocalDateTime } catch { return $null }
}
# Uniform, human-readable timestamp for the RAW files ("" when no date).
function Format-DateTime { param($dt)
    if($dt){ return $dt.ToString("yyyy-MM-dd HH:mm:ss") } else { return "" }
}
function Test-IsDefaultSafe { param([string]$n)
    if($DefaultSafes -contains $n){return $true}
    foreach($p in $DefaultSafePrefixes){ if($n -like $p){return $true} }; return $false }
function Test-IsDefaultMember { param([string]$n)
    foreach($p in $DefaultMembersPatterns){ if($n -like $p){return $true} }; return $false }
function Test-IsDefaultGroup { param([string]$n)
    foreach($p in $DefaultGroupPatterns){ if($n -like $p){return $true} }; return $false }
function Get-Region { param([string]$s)
    foreach($k in $RegionPrefixes.Keys){ if($s.ToUpper().StartsWith($k)){return $RegionPrefixes[$k]} }
    return "Non-standard" }
function Get-Tier { param([string]$s)
    if($s -match $TierRegex){ "T$($matches[2])" } else { "Untagged" }
}
function Get-OSCategory { param([string]$p)
    foreach($x in $WindowsPlatformPatterns){ if($p -like $x){return "Windows"} }
    foreach($x in $UnixPlatformPatterns){ if($p -like $x){return "Unix/Linux"} }
    return "Other" }
function Get-RotationDays { param([string]$p)
    foreach($k in $RotationPolicyDays.Keys){ if($p -like $k){return $RotationPolicyDays[$k]} }
    return $DefaultRotationDays }

# Only for use when $SafeName is the LAST segment of the URL path (e.g. a
# single-safe lookup). CyberArk's API misreads a trailing dot in the final
# path segment as a format suffix, so that case needs a trailing slash.
# Do NOT use this for a safe name that's a middle segment (e.g. .../Safes/
# {name}/Members) - appending the slash there produces a double slash
# ("...//Members") since another path segment already follows.
function Get-SafeUrlSegment {
    param([string]$SafeName)
    $encoded = [Uri]::EscapeDataString($SafeName)
    if ($SafeName -match '\.') { return "$encoded/" }
    return $encoded
}

function Get-SafeMembersForSafe {
    param([string]$SafeName)
    # SafeName is a middle segment here (.../Safes/{name}/Members), so it's
    # just escaped directly - no trailing slash (see Get-SafeUrlSegment note).
    $urlSeg = [Uri]::EscapeDataString($SafeName)
    $all = @(); $off = 0
    do {
        $resp = Invoke-ApiGet -Uri "$PvwaBase/Safes/$urlSeg/Members?limit=$PageLimit&offset=$off"
        if (-not $resp) { break }
        $batch = $resp.value
        if (-not $batch) { break }
        $all += $batch
        $off += $PageLimit
    } while ($batch.Count -eq $PageLimit)

    # Return both raw member details and the criteria-based flag; the Safe
    # Members stage projects this into the _Raw and _Info files.
    return @($all | ForEach-Object {
        [pscustomobject]@{
            SafeName                 = $SafeName
            MemberName               = $_.memberName
            MemberID                 = $_.memberId
            MemberType               = $_.memberType
            IsPredefinedUser         = $_.isPredefinedUser
            IsReadOnly               = $_.isReadOnly
            MembershipExpirationDate = Format-DateTime (ConvertFrom-Unix $_.membershipExpirationDate)
            IsDefaultMember          = Test-IsDefaultMember $_.memberName
            Permissions              = ($_.permissions | ConvertTo-Json -Compress)
        }
    })
}

# ── ACCOUNT ACTIVITY COLLECTION (throttled runspace pool, resumable cache) ───────
# Fans out one /Accounts/{id}/Activities call per account across a runspace pool
# (works on Windows PowerShell 5.1 - not the PS7-only ForEach-Object -Parallel).
# For each account we scan the returned activities for the wanted "usage" actions
# and keep the most-recent one (max timestamp) => that's the account's last-used
# date. No usage action found => never used. Order-independent (we take the max),
# so it's correct regardless of how the API sorts the activity list.
#
# Token handling: runspaces don't share $Global: state, so we seed each batch
# with a freshly-refreshed bearer token; batches are sized to finish well inside
# the token lifetime. Results are cached to disk after every batch so a run can
# be interrupted and resumed (and re-runs only refetch stale/missing accounts).
function Invoke-AccountActivityCollection {
    param([object[]]$Accounts)

    $cachePath = Join-Path $PSScriptRoot "AccountActivity_Cache.json"
    $cache = @{}
    if ((Test-Path $cachePath) -and -not $ActivityForceRefresh) {
        try {
            $loaded = Get-Content -Path $cachePath -Raw | ConvertFrom-Json
            foreach ($p in $loaded.PSObject.Properties) { $cache[$p.Name] = $p.Value }
            Write-Log "Loaded activity cache: $($cache.Count) entries." INFO
        } catch { Write-Log "Could not read activity cache ($($_.Exception.Message)) - starting fresh." WARN }
    }

    # Decide which accounts still need a (re)fetch vs. a fresh-enough cache hit.
    $cutoff  = (Get-Date).AddHours(-1 * $ActivityCacheTTLHours)
    $toFetch = New-Object System.Collections.Generic.List[string]
    foreach ($acct in $Accounts) {
        $id  = $acct.AccountID
        $hit = $cache[$id]
        $fresh = $false
        if ($hit -and -not $ActivityForceRefresh -and ($hit.Status -eq "Used" -or $hit.Status -eq "NeverUsed") -and $hit.FetchedAt) {
            $ft = $null; try { $ft = [datetime]$hit.FetchedAt } catch { $ft = $null }
            if ($ft -and $ft -ge $cutoff) { $fresh = $true }
        }
        if (-not $fresh) { [void]$toFetch.Add($id) }
    }
    Write-Log "Account activity: $($Accounts.Count) in scope, $($toFetch.Count) to fetch, $($Accounts.Count - $toFetch.Count) reused from cache." INFO

    if ($toFetch.Count -gt 0) {
        # Self-contained worker: one account -> its usage rollup. No outer funcs.
        $worker = {
            param($AccountID,$PvwaBase,$Token,$MaxRetries,$RetryWaitSeconds,$UsagePatterns)
            $headers = @{ Authorization = "Bearer $Token" }
            $uri = "$PvwaBase/Accounts/$AccountID/Activities"
            $resp = $null; $attempt = 0; $err = $null
            while ($attempt -le $MaxRetries) {
                $attempt++
                try { $resp = Invoke-RestMethod -Uri $uri -Method GET -Headers $headers -ErrorAction Stop; $err = $null; break }
                catch {
                    $code = if ($_.Exception.Response) { [int]$_.Exception.Response.StatusCode } else { 0 }
                    $err  = "$code $($_.Exception.Message)"
                    if ($code -eq 400 -or $code -eq 401 -or $code -eq 403 -or $code -eq 404) { break }
                    if ($attempt -le $MaxRetries) { Start-Sleep -Seconds $RetryWaitSeconds } else { break }
                }
            }
            if ($null -eq $resp -and $err) {
                return [pscustomobject]@{ AccountID=$AccountID; Status="Error"; Error=$err;
                    LastUsedEpoch=$null; LastUsedType=$null; LastUsedUser=$null; LastUsedAction=$null; LastUsedReason=$null; ActivitiesScanned=0 }
            }
            $acts = @($resp.Activities); if (-not $acts) { $acts = @($resp.GetAccountActivitiesResult) }
            $bestEpoch=$null; $bestType=$null; $bestUser=$null; $bestAction=$null; $bestReason=$null
            foreach ($act in $acts) {
                $action = if ($act.Action) { "$($act.Action)" } else { "" }
                if ([string]::IsNullOrEmpty($action)) { continue }
                $type = $null
                foreach ($label in $UsagePatterns.Keys) {
                    foreach ($pat in $UsagePatterns[$label]) { if ($action -like $pat) { $type = $label; break } }
                    if ($type) { break }
                }
                if (-not $type) { continue }
                $epochRaw = if ($act.Date) { $act.Date } elseif ($act.Time) { $act.Time } else { $null }
                $epoch = $null; if ($epochRaw) { try { $epoch = [long]$epochRaw } catch { $epoch = $null } }
                if ($null -eq $epoch) { continue }
                if ($null -eq $bestEpoch -or $epoch -gt $bestEpoch) {
                    $bestEpoch = $epoch; $bestType = $type
                    $bestUser   = if ($act.User)   { "$($act.User)" }   else { "" }
                    $bestAction = $action
                    $bestReason = if ($act.Reason) { "$($act.Reason)" } elseif ($act.ActivityDetails) { "$($act.ActivityDetails)" } else { "" }
                }
            }
            $status = if ($bestEpoch) { "Used" } else { "NeverUsed" }
            return [pscustomobject]@{ AccountID=$AccountID; Status=$status; Error=$null
                LastUsedEpoch=$bestEpoch; LastUsedType=$bestType; LastUsedUser=$bestUser
                LastUsedAction=$bestAction; LastUsedReason=$bestReason; ActivitiesScanned=$acts.Count }
        }

        $ids = $toFetch.ToArray()
        $batchNum = 0
        for ($i = 0; $i -lt $ids.Count; $i += $ActivityBatchSize) {
            $batchNum++
            $end   = [Math]::Min($i + $ActivityBatchSize - 1, $ids.Count - 1)
            $slice = @($ids[$i..$end])

            # Refresh the token if it's expired or within 2 min of expiry, then seed it.
            if (((Get-Date).AddSeconds(120)) -ge $Global:TokenExpiry) { Get-AuthToken }
            $seed = $Global:Token

            $pool = [runspacefactory]::CreateRunspacePool(1, $ActivityThrottleLimit)
            $pool.Open()
            $jobs = New-Object System.Collections.Generic.List[object]
            foreach ($id in $slice) {
                $ps = [powershell]::Create()
                $ps.RunspacePool = $pool
                [void]$ps.AddScript($worker.ToString()).AddArgument($id).AddArgument($PvwaBase).AddArgument($seed).AddArgument($MaxRetries).AddArgument($RetryWaitSeconds).AddArgument($UsageActivityPatterns)
                $jobs.Add([pscustomobject]@{ Pipe = $ps; Handle = $ps.BeginInvoke() })
            }
            foreach ($j in $jobs) {
                $res = $null
                try { $res = $j.Pipe.EndInvoke($j.Handle) } catch { $res = $null }
                finally { $j.Pipe.Dispose() }
                $r = $res | Select-Object -First 1
                if ($r) {
                    $cache[$r.AccountID] = [pscustomobject]@{
                        Status=$r.Status; LastUsedEpoch=$r.LastUsedEpoch; LastUsedType=$r.LastUsedType
                        LastUsedUser=$r.LastUsedUser; LastUsedAction=$r.LastUsedAction; LastUsedReason=$r.LastUsedReason
                        ActivitiesScanned=$r.ActivitiesScanned; Error=$r.Error
                        FetchedAt=(Get-Date -Format "yyyy-MM-dd HH:mm:ss")
                    }
                }
            }
            $pool.Close(); $pool.Dispose()

            try { ($cache | ConvertTo-Json -Depth 5) | Set-Content -Path $cachePath -Encoding UTF8 } catch { }
            Write-Log "  activity batch $batchNum : fetched $($slice.Count) (cache now $($cache.Count))" DEBUG
        }
    }

    return $cache
}

# ══════════════════════════════════════════════════════════════════════════════
#  RUN
# ══════════════════════════════════════════════════════════════════════════════
Write-Log "=== CyberArk Operational Metrics Export ===" SECTION
Write-Log "PowerShell version: $($PSVersionTable.PSVersion)" INFO
Get-AuthToken

# ── STEP 1 : SAFES ──────────────────────────────────────────────────────────────
Write-Log "Collecting Safes..." SECTION
$SafesRaw = Get-AllPaged -BaseUri "$PvwaBase/Safes" -ValueProp "value"

# RAW (readable): flatten each fetched Safe, epoch -> real dates.
$SafesRawOut = @(foreach($s in $SafesRaw){
    [pscustomobject]@{
        SafeName                  = $s.safeName
        SafeUrlId                 = $s.safeUrlId
        SafeNumber                = $s.safeNumber
        Description               = $s.description
        Location                  = $s.location
        Creator                   = $s.creator.name
        ManagingCPM               = $s.managingCPM
        NumberOfAccounts          = $s.numberOfAccounts
        OLACEnabled               = $s.olacEnabled
        AutoPurgeEnabled          = $s.autoPurgeEnabled
        NumberOfVersionsRetention = $s.numberOfVersionsRetention
        NumberOfDaysRetention     = $s.numberOfDaysRetention
        CreationTime              = Format-DateTime (ConvertFrom-Unix      $s.creationTime)
        LastModificationTime      = Format-DateTime (ConvertFrom-UnixMicro $s.lastModificationTime)
    }
})
$SafesRawOut | Export-Csv "$OutputDir\Safes_Raw.csv" -NoTypeInformation -Encoding UTF8

$SafeFact = @(foreach($s in $SafesRaw){
    $def = Test-IsDefaultSafe $s.safeName
    $created = ConvertFrom-Unix $s.creationTime
    [pscustomobject]@{
        SafeName      = $s.safeName
        IsDefault     = $def
        Region        = if($def){"N/A-Default"}else{Get-Region $s.safeName}
        Tier          = if($def){"N/A-Default"}else{Get-Tier $s.safeName}
        ManagingCPM   = $s.managingCPM
        HasCPM        = -not [string]::IsNullOrWhiteSpace($s.managingCPM)
        NumberOfAccts = [int]$s.numberOfAccounts
        IsEmpty       = ([int]$s.numberOfAccounts -eq 0)
        CreatedDate   = if($created){$created.ToString("yyyy-MM-dd")}else{""}
        RecentlyCreated = ($created -and (New-TimeSpan -Start $created -End (Get-Date)).Days -le $OnboardingWindowDays)
    }
})
$SafeFact | Export-Csv "$OutputDir\Safes_Info.csv" -NoTypeInformation -Encoding UTF8
$SafeLookup=@{}; foreach($f in $SafeFact){ $SafeLookup[$f.SafeName]=$f }
Write-Log "Safes: total=$($SafesRaw.Count) default=$(@($SafeFact|?{$_.IsDefault}).Count)" SUCCESS

# ── STEP 2 : USERS (login activity from bulk field) ──────────────────────────────
Write-Log "Collecting Users..." SECTION
$UsersResp = Invoke-ApiGet -Uri "$PvwaBase/Users?ExtendedDetails=True"
$UsersRaw  = if($UsersResp.Users){$UsersResp.Users}else{@()}

# RAW (readable): flatten each fetched User, epoch -> real date.
$UsersRawOut = @(foreach($u in $UsersRaw){
    [pscustomobject]@{
        UserName                = $u.username
        UserID                  = $u.id
        Source                  = $u.source
        UserType                = $u.userType
        ComponentUser           = $u.componentUser
        Enabled                 = $u.enableUser
        Suspended               = $u.suspended
        Location                = $u.location
        PasswordNeverExpires    = $u.passwordNeverExpires
        FirstName               = $u.personalDetails.firstName
        LastName                = $u.personalDetails.lastName
        BusinessEmail           = $u.internet.businessEmail
        VaultAuthorization      = ($u.vaultAuthorization -join "; ")
        LastSuccessfulLoginDate = Format-DateTime (ConvertFrom-Unix $u.lastSuccessfulLoginDate)
    }
})
$UsersRawOut | Export-Csv "$OutputDir\Users_Raw.csv" -NoTypeInformation -Encoding UTF8

$UserFact = @(foreach($u in $UsersRaw){
    $isComp = ($u.componentUser -eq $true) -or (Test-IsDefaultMember $u.username) -or ($u.userType -ne "EPVUser")
    $lastLogin = ConvertFrom-Unix $u.lastSuccessfulLoginDate
    $days = if($lastLogin){(New-TimeSpan -Start $lastLogin -End (Get-Date)).Days}else{$null}
    [pscustomobject]@{
        UserName      = $u.username
        UserType      = $u.userType
        IsComponent   = $isComp
        Enabled       = $u.enableUser
        LastLoginDate = if($lastLogin){$lastLogin.ToString("yyyy-MM-dd")}else{"Never"}
        DaysSinceLogin= $days
        LoginStatus   = if(-not $lastLogin){"Never Logged In"}
                        elseif($days -le $LoginWindowDays){"Active (<= $LoginWindowDays d)"}
                        else{"Dormant (> $LoginWindowDays d)"}
    }
})
$UserFact | Export-Csv "$OutputDir\Users_Info.csv" -NoTypeInformation -Encoding UTF8
$realUsers = @($UserFact | ?{ -not $_.IsComponent })
Write-Log "Users: total=$($UsersRaw.Count) real=$($realUsers.Count) active=$(@($realUsers|?{$_.LoginStatus -like 'Active*'}).Count)" SUCCESS

# ── STEP 3 : GROUPS ──────────────────────────────────────────────────────────────
Write-Log "Collecting Groups..." SECTION
$GroupsResp=Invoke-ApiGet -Uri "$PvwaBase/UserGroups"
$GroupsRaw = if($GroupsResp.value){$GroupsResp.value}else{@()}

# RAW (readable): flatten each fetched Group.
$GroupsRawOut = @(foreach($g in $GroupsRaw){
    [pscustomobject]@{
        GroupName = $g.groupName
        GroupID   = $g.id
        GroupType = $g.groupType
        Directory = $g.directory
        Location  = $g.location
    }
})
$GroupsRawOut | Export-Csv "$OutputDir\Groups_Raw.csv" -NoTypeInformation -Encoding UTF8
$GroupFact = @(foreach($g in $GroupsRaw){
    [pscustomobject]@{ GroupName=$g.groupName; GroupType=$g.groupType; IsDefault=(Test-IsDefaultGroup $g.groupName); Directory=$g.directory }
})
$GroupFact | Export-Csv "$OutputDir\Groups_Info.csv" -NoTypeInformation -Encoding UTF8
Write-Log "Groups: total=$($GroupsRaw.Count)" SUCCESS

# ── STEP 4 : PLATFORMS ───────────────────────────────────────────────────────────
Write-Log "Collecting Platforms..." SECTION
$PlatResp=Invoke-ApiGet -Uri "$PvwaBase/Platforms"
$PlatRaw = if($PlatResp.Platforms){$PlatResp.Platforms}else{@()}

# RAW (readable): flatten each fetched Platform's general block.
$PlatRawOut = @(foreach($p in $PlatRaw){
    [pscustomobject]@{
        PlatformID     = $p.general.id
        PlatformName   = $p.general.name
        SystemType     = $p.general.systemType
        Active         = $p.general.active
        PlatformBaseID = $p.general.platformBaseID
        PlatformType   = $p.general.platformType
    }
})
$PlatRawOut | Export-Csv "$OutputDir\Platforms_Raw.csv" -NoTypeInformation -Encoding UTF8
$PlatDim = @(foreach($p in $PlatRaw){
    [pscustomobject]@{
        PlatformID   = $p.general.id
        PlatformName = $p.general.name
        SystemType   = $p.general.systemType
        Active       = $p.general.active
        RotationDays = Get-RotationDays $p.general.id
    }
})
$PlatDim | Export-Csv "$OutputDir\Platforms_Info.csv" -NoTypeInformation -Encoding UTF8
Write-Log "Platforms: total=$($PlatRaw.Count) active=$(@($PlatDim|?{$_.Active}).Count)" SUCCESS

# ── STEP 5 : ACCOUNTS (star table) ───────────────────────────────────────────────
Write-Log "Collecting Accounts..." SECTION
$AcctRaw = Get-AllPaged -BaseUri "$PvwaBase/Accounts" -ValueProp "value"

# RAW (readable): flatten each fetched Account (incl. the secretManagement
# sub-object), epoch -> real dates.
$AcctRawOut = @(foreach($a in $AcctRaw){
    $sm = $a.secretManagement
    [pscustomobject]@{
        AccountID                  = $a.id
        Name                       = $a.name
        UserName                   = $a.userName
        Address                    = $a.address
        SafeName                   = $a.safeName
        PlatformID                 = $a.platformId
        SecretType                 = $a.secretType
        AutomaticManagementEnabled = $sm.automaticManagementEnabled
        ManualManagementReason     = $sm.manualManagementReason
        SecretStatus               = $sm.status
        LastModifiedTime           = Format-DateTime (ConvertFrom-Unix $sm.lastModifiedTime)
        LastVerifiedTime           = Format-DateTime (ConvertFrom-Unix $sm.lastVerifiedTime)
        LastReconciledTime         = Format-DateTime (ConvertFrom-Unix $sm.lastReconciledTime)
        CreatedTime                = Format-DateTime (ConvertFrom-Unix $a.createdTime)
        CategoryModificationTime   = Format-DateTime (ConvertFrom-Unix $a.categoryModificationTime)
    }
})
$AcctRawOut | Export-Csv "$OutputDir\Accounts_Raw.csv" -NoTypeInformation -Encoding UTF8

$AcctFact = @(foreach($a in $AcctRaw){
    $sfi = $SafeLookup[$a.safeName]
    $defSafe = if($sfi){$sfi.IsDefault}else{Test-IsDefaultSafe $a.safeName}
    $sm  = $a.secretManagement
    $auto= ($sm.automaticManagementEnabled -eq $true)
    $lastChg = ConvertFrom-Unix $sm.lastModifiedTime
    $lastVer = ConvertFrom-Unix $sm.lastVerifiedTime
    $created = ConvertFrom-Unix $a.createdTime
    $dChg = if($lastChg){(New-TimeSpan -Start $lastChg -End (Get-Date)).Days}else{$null}
    $dVer = if($lastVer){(New-TimeSpan -Start $lastVer -End (Get-Date)).Days}else{$null}
    $rot  = Get-RotationDays $a.platformId
    $comp = switch("$($sm.status)"){ "success"{"Compliant"} "failure"{"Non-Compliant"} default{"Pending/Unknown"} }

    [pscustomobject]@{
        AccountID       = $a.id
        UserName        = $a.userName
        Address         = $a.address
        SafeName        = $a.safeName
        IsDefaultSafe   = $defSafe
        Region          = if($sfi){$sfi.Region}else{Get-Region $a.safeName}
        Tier            = if($sfi){$sfi.Tier}else{Get-Tier $a.safeName}
        PlatformID      = $a.platformId
        OSCategory      = Get-OSCategory $a.platformId
        AutoManaged     = $auto
        MgmtTechnique   = if($auto){"Automatic (APM)"}else{"Manual (MPM)"}
        ManualReason    = $sm.manualManagementReason
        ComplianceStatus= $comp
        SecretStatus    = $sm.status
        LastChangeDate  = if($lastChg){$lastChg.ToString("yyyy-MM-dd")}else{""}
        DaysSinceChange = $dChg
        ExpectedRotationDays = $rot
        RotationOverdue = if($dChg -ne $null){ $dChg -gt $rot }else{$false}
        LastVerifyDate  = if($lastVer){$lastVer.ToString("yyyy-MM-dd")}else{""}
        DaysSinceVerify = $dVer
        VerifyStatus    = if(-not $auto){"N/A (Manual)"}
                          elseif(-not $lastVer){"Never Verified"}
                          elseif($dVer -gt $VerifyOverdueDays){"Overdue (> $VerifyOverdueDays d)"}
                          else{"OK"}
        IsStale         = if($dChg -ne $null){ $dChg -ge $StaleAccountDays }else{$false}
        CreatedDate     = if($created){$created.ToString("yyyy-MM-dd")}else{""}
        CreatedMonth    = if($created){$created.ToString("yyyy-MM")}else{""}
        RecentlyOnboarded = ($created -and (New-TimeSpan -Start $created -End (Get-Date)).Days -le $OnboardingWindowDays)
    }
})
$AcctFact | Export-Csv "$OutputDir\Accounts_Info.csv" -NoTypeInformation -Encoding UTF8
Write-Log "Accounts: total=$($AcctRaw.Count) business=$(@($AcctFact|?{-not $_.IsDefaultSafe}).Count)" SUCCESS

# ── STEP 6 : METRICS SUMMARY (long format) ───────────────────────────────────────
Write-Log "Building metrics summary..." SECTION
$biz = @($AcctFact | ?{ -not $_.IsDefaultSafe })
$bizSafes = @($SafeFact | ?{ -not $_.IsDefault })
$rows = New-Object System.Collections.Generic.List[object]
function Add-M { param($M,$D,$V) $rows.Add([pscustomobject]@{Metric=$M;Dimension=$D;Value=$V}) }

# Inventory
foreach($g in $bizSafes | Group-Object Region){ Add-M "Safes by Region" $g.Name $g.Count }
Add-M "Platforms Total" "All" $PlatDim.Count
Add-M "Platforms Active" "Active" (@($PlatDim|?{$_.Active}).Count)
$usedPlat = $biz | Group-Object PlatformID | Select-Object -Expand Name
Add-M "Platforms Defined-but-Unused" "All" (@($PlatDim | ?{ $usedPlat -notcontains $_.PlatformID }).Count)
Add-M "Empty Safes" "All" (@($bizSafes|?{$_.IsEmpty}).Count)
Add-M "Safes without CPM" "All" (@($bizSafes|?{-not $_.HasCPM}).Count)
Add-M "Non-standard Safe Names" "All" (@($bizSafes|?{$_.Region -eq "Non-standard"}).Count)
$bizSafes | Sort-Object NumberOfAccts -Desc | Select-Object -First $TopNSafes |
    ForEach-Object { Add-M "Top Safes by Accounts" $_.SafeName $_.NumberOfAccts }

# Region x Tier
foreach($g in $biz | Group-Object Region,Tier){ Add-M "Accounts Region x Tier" $g.Name $g.Count }

# Health
Add-M "Total Managed Accounts" "All" $biz.Count
Add-M "Failed Accounts (Total)" "All" (@($biz|?{$_.ComplianceStatus -eq "Non-Compliant"}).Count)
foreach($g in ($biz|?{$_.ComplianceStatus -eq "Non-Compliant"} | Group-Object OSCategory)){ Add-M "Failed by OS" $g.Name $g.Count }
foreach($g in ($biz|?{$_.ComplianceStatus -eq "Non-Compliant"} | Group-Object Region)){ Add-M "Failed by Region" $g.Name $g.Count }
foreach($g in ($biz|?{$_.ComplianceStatus -eq "Non-Compliant"} | Group-Object Tier)){ Add-M "Failed by Tier" $g.Name $g.Count }
foreach($g in $biz | Group-Object MgmtTechnique){ Add-M "Mgmt Technique" $g.Name $g.Count }
Add-M "Non-Compliant (Manual/MPM)" "MPM" (@($biz|?{$_.ComplianceStatus -eq "Non-Compliant" -and -not $_.AutoManaged}).Count)
Add-M "Non-Compliant (Auto/APM)" "APM" (@($biz|?{$_.ComplianceStatus -eq "Non-Compliant" -and $_.AutoManaged}).Count)
Add-M "Pending First Management" "All" (@($biz|?{$_.ComplianceStatus -eq "Pending/Unknown"}).Count)
foreach($g in $biz | Group-Object VerifyStatus){ Add-M "Verification Status" $g.Name $g.Count }
Add-M "Rotation Overdue" "All" (@($biz|?{$_.RotationOverdue}).Count)
foreach($g in ($biz|?{$_.RotationOverdue} | Group-Object Region)){ Add-M "Rotation Overdue by Region" $g.Name $g.Count }
foreach($g in ($biz|?{$_.RotationOverdue} | Group-Object Tier)){ Add-M "Rotation Overdue by Tier" $g.Name $g.Count }
foreach($g in ($biz|?{$_.RotationOverdue} | Group-Object OSCategory)){ Add-M "Rotation Overdue by OS" $g.Name $g.Count }
Add-M "Stale Accounts (No Change >= $StaleAccountDays d)" "All" (@($biz|?{$_.IsStale}).Count)
Add-M "Verification Overdue" "All" (@($biz|?{$_.VerifyStatus -like 'Overdue*'}).Count)
Add-M "Never Verified (Auto-Managed)" "All" (@($biz|?{$_.VerifyStatus -eq 'Never Verified'}).Count)

# ── STEP 7 : ONBOARDING TREND (last $TrendLookbackMonths months) ────────────────
Write-Log "Building onboarding trend (last $TrendLookbackMonths months)..." SECTION
$trendCutoff = [datetime]::new((Get-Date).AddMonths(-1 * $TrendLookbackMonths).Year, (Get-Date).AddMonths(-1 * $TrendLookbackMonths).Month, 1)

$acctTrend = $biz | ?{ $_.CreatedMonth -and ([datetime]::ParseExact("$($_.CreatedMonth)-01","yyyy-MM-dd",$null) -ge $trendCutoff) } |
    Group-Object CreatedMonth | Sort-Object Name
foreach($g in $acctTrend){ Add-M "Accounts Onboarded by Month" $g.Name $g.Count }

$safeTrend = $bizSafes | ?{ $_.CreatedDate -and ([datetime]$_.CreatedDate -ge $trendCutoff) } |
    ForEach-Object { [pscustomobject]@{ Month = ([datetime]$_.CreatedDate).ToString("yyyy-MM") } } |
    Group-Object Month | Sort-Object Name
foreach($g in $safeTrend){ Add-M "Safes Onboarded by Month" $g.Name $g.Count }

Add-M "Accounts Recently Onboarded (<= $OnboardingWindowDays d)" "All" (@($biz|?{$_.RecentlyOnboarded}).Count)
Add-M "Safes Recently Created (<= $OnboardingWindowDays d)" "All" (@($bizSafes|?{$_.RecentlyCreated}).Count)

# ── STEP 8 : SAFE MEMBERS (optional - 1 call per safe, sequential) ──────────────
$MembersRaw = @()
if ($CollectSafeMembers) {
    Write-Log "Collecting Safe Members for $($SafeFact.Count) safes (sequential)..." SECTION
    $memberSw = [System.Diagnostics.Stopwatch]::StartNew()

    $MembersRaw = @(foreach ($sn in $SafeFact.SafeName) { Get-SafeMembersForSafe -SafeName $sn })

    $memberSw.Stop()
    Write-Log "Safe Members collected: $($MembersRaw.Count) rows in $([Math]::Round($memberSw.Elapsed.TotalSeconds,1))s" SUCCESS

    # RAW (readable): raw member details. INFO: criteria-based classification.
    $MembersRaw | Select-Object SafeName,MemberName,MemberID,MemberType,IsPredefinedUser,IsReadOnly,MembershipExpirationDate,Permissions |
        Export-Csv "$OutputDir\SafeMembers_Raw.csv" -NoTypeInformation -Encoding UTF8
    $MembersRaw | Select-Object SafeName,MemberName,MemberType,IsDefaultMember,Permissions |
        Export-Csv "$OutputDir\SafeMembers_Info.csv" -NoTypeInformation -Encoding UTF8

    $bizMembers = @($MembersRaw | ?{ -not (Test-IsDefaultSafe $_.SafeName) })
    foreach($g in $bizMembers | Group-Object MemberType){ Add-M "Safe Members by Type" $g.Name $g.Count }
    $safesWithMembers = $bizMembers | Group-Object SafeName | Select-Object -Expand Name
    $orphanSafes = @($bizSafes | ?{ $safesWithMembers -notcontains $_.SafeName })
    Add-M "Safes With No Members Found" "All" $orphanSafes.Count
} else {
    Write-Log "CollectSafeMembers=`$false - skipping Safe Members stage (1 call/safe). Set `$CollectSafeMembers=`$true to enable." WARN
}

# ── STEP 9 : ACCOUNT USAGE (optional - "onboarded vs used", ~1 call/business acct)
$UsageInfo = @()
if ($CollectAccountActivity) {
    Write-Log "Collecting account activity for $($biz.Count) business accounts (throttle $ActivityThrottleLimit)..." SECTION
    $usageSw = [System.Diagnostics.Stopwatch]::StartNew()

    $cache = Invoke-AccountActivityCollection -Accounts $biz
    $now = Get-Date

    # INFO: per-account rollup (onboarded vs used).
    $UsageInfo = @(foreach ($a in $biz) {
        $c = $cache[$a.AccountID]
        $lastUsed = if ($c -and $c.LastUsedEpoch) { ConvertFrom-Unix $c.LastUsedEpoch } else { $null }
        $dUsed = if ($lastUsed) { (New-TimeSpan -Start $lastUsed -End $now).Days } else { $null }
        $status = if ($c) { $c.Status } else { "Not Collected" }
        [pscustomobject]@{
            AccountID     = $a.AccountID
            UserName      = $a.UserName
            Address       = $a.Address
            SafeName      = $a.SafeName
            Region        = $a.Region
            Tier          = $a.Tier
            PlatformID    = $a.PlatformID
            OnboardedDate = $a.CreatedDate
            OnboardedMonth= $a.CreatedMonth
            UsageStatus   = $status
            Used          = ($status -eq "Used")
            LastUsedDate  = if ($lastUsed) { $lastUsed.ToString("yyyy-MM-dd") } else { "" }
            LastUsedType  = if ($c) { $c.LastUsedType } else { "" }
            DaysSinceUsed = $dUsed
            UsedLast30    = ($null -ne $dUsed -and $dUsed -le 30)
            UsedLast90    = ($null -ne $dUsed -and $dUsed -le 90)
            ActivitiesScanned = if ($c) { $c.ActivitiesScanned } else { 0 }
            Error         = if ($c) { $c.Error } else { "" }
        }
    })
    $UsageInfo | Export-Csv "$OutputDir\AccountUsage_Info.csv" -NoTypeInformation -Encoding UTF8

    # RAW (readable): the most-recent matched usage event per used account.
    $UsageRaw = @($UsageInfo | ?{ $_.Used } | ForEach-Object {
        $c = $cache[$_.AccountID]
        [pscustomobject]@{
            AccountID    = $_.AccountID
            SafeName     = $_.SafeName
            UserName     = $_.UserName
            ActivityDate = $_.LastUsedDate
            ActivityType = $_.LastUsedType
            Action       = if ($c) { $c.LastUsedAction } else { "" }
            PerformedBy  = if ($c) { $c.LastUsedUser } else { "" }
            Reason       = if ($c) { $c.LastUsedReason } else { "" }
        }
    })
    $UsageRaw | Export-Csv "$OutputDir\AccountUsage_Raw.csv" -NoTypeInformation -Encoding UTF8

    $usageSw.Stop()
    $usedCount  = @($UsageInfo | ?{ $_.Used }).Count
    $neverCount = @($UsageInfo | ?{ $_.UsageStatus -eq 'NeverUsed' }).Count
    $errCount   = @($UsageInfo | ?{ $_.UsageStatus -eq 'Error' }).Count
    Write-Log "Account usage: used=$usedCount never=$neverCount errors=$errCount in $([Math]::Round($usageSw.Elapsed.TotalSeconds,1))s" SUCCESS

    # Metrics
    Add-M "Business Accounts (Usage Scope)" "All" $UsageInfo.Count
    Add-M "Accounts Used" "All" $usedCount
    Add-M "Accounts Never Used" "All" $neverCount
    Add-M "Accounts Used (last 30d)" "All" (@($UsageInfo | ?{ $_.UsedLast30 }).Count)
    Add-M "Accounts Used (last 90d)" "All" (@($UsageInfo | ?{ $_.UsedLast90 }).Count)
    if ($errCount -gt 0) { Add-M "Account Usage Lookup Errors" "All" $errCount }
    foreach ($g in ($UsageInfo | ?{ $_.UsageStatus -eq 'NeverUsed' } | Group-Object Region)) { Add-M "Never Used by Region" $g.Name $g.Count }
    foreach ($g in ($UsageInfo | ?{ $_.UsageStatus -eq 'NeverUsed' } | Group-Object Tier))   { Add-M "Never Used by Tier" $g.Name $g.Count }
    foreach ($g in ($UsageInfo | ?{ $_.Used } | Group-Object LastUsedType))                  { Add-M "Last Usage by Type" $g.Name $g.Count }
    foreach ($g in ($UsageInfo | ?{ $_.OnboardedMonth } | Group-Object OnboardedMonth | Sort-Object Name)) {
        Add-M "Onboarded by Month (Usage Scope)" $g.Name $g.Count
        Add-M "Used by Onboarding Month" $g.Name (@($g.Group | ?{ $_.Used }).Count)
    }
} else {
    Write-Log "CollectAccountActivity=`$false - skipping Account Usage stage (~1 call/business acct). Set `$CollectAccountActivity=`$true to enable." WARN
}

# ── STEP 10 : EXPORT + CONSOLE SUMMARY ──────────────────────────────────────────
$rows | Export-Csv "$OutputDir\Metrics_Summary.csv" -NoTypeInformation -Encoding UTF8
Write-Log "Metrics summary rows: $($rows.Count)" SUCCESS

$Divider = "=" * 75
Write-Host ""
Write-Host $Divider -ForegroundColor White
Write-Host "  CYBERARK OPERATIONAL METRICS - RUN SUMMARY" -ForegroundColor White
Write-Host $Divider -ForegroundColor White
Write-Host ("  Safes               : {0} (business: {1})" -f $SafesRaw.Count, $bizSafes.Count) -ForegroundColor White
Write-Host ("  Users               : {0} (real: {1})" -f $UsersRaw.Count, $realUsers.Count) -ForegroundColor White
Write-Host ("  Groups              : {0}" -f $GroupsRaw.Count) -ForegroundColor White
Write-Host ("  Platforms           : {0}" -f $PlatRaw.Count) -ForegroundColor White
Write-Host ("  Accounts            : {0} (business: {1})" -f $AcctRaw.Count, $biz.Count) -ForegroundColor White
if ($CollectSafeMembers) {
    Write-Host ("  Safe Members        : {0}" -f @($MembersRaw).Count) -ForegroundColor White
}
if ($CollectAccountActivity) {
    Write-Host ("  Account Usage       : {0} used / {1} never (of {2})" -f `
        @($UsageInfo|?{$_.Used}).Count, @($UsageInfo|?{$_.UsageStatus -eq 'NeverUsed'}).Count, @($UsageInfo).Count) -ForegroundColor White
}
Write-Host ("  Metrics Rows        : {0}" -f $rows.Count) -ForegroundColor Green
Write-Host ("  Output              : {0}" -f $OutputDir) -ForegroundColor Green
Write-Host $Divider -ForegroundColor White

Write-Log "=== CyberArk Operational Metrics Export Complete ===" SECTION
