Add-M "Non-standard Safe Names" "All" (@($bizSafes|?{$_.Region -eq "Non-standard"}).Count)
$bizSafes | Sort-Object NumberOfAccts -Desc | Select-Object -First $TopNSafes |
    ForEach-Object { Add-M "Top Safes by Accounts" $_.SafeName $_.NumberOfAccts }

# Region x Tier
foreach($g in $biz | Group-Object Region,Tier){ Add-M "Accounts Region x Tier" $g.Name $g.Count }

# Health
Add-M "Total Managed Accounts" "All" $biz.Count
Add-M "Failed Accounts (Total)" "All" (@($biz|?{$_.ComplianceStatus -eq "Non-Compliant"}).Count)
foreach($g in ($biz|?{$_.ComplianceStatus -eq "Non-Compliant"} | Group-Object OSCategory)){ Add-M "Failed by OS" $g.Name $g.Count }
foreach($g in ($biz|?{$_.ComplianceStatus -eq "Non-Compliant"} | Group-Object Region)){ Add-M "Failed by Region" $g.Name $g.Count }
foreach($g in ($biz|?{$_.ComplianceStatus -eq "Non-Compliant"} | Group-Object Tier)){ Add-M "Failed by Tier" $g.Name $g.Count }
foreach($g in $biz | Group-Object MgmtTechnique){ Add-M "Mgmt Technique" $g.Name $g.Count }
Add-M "Non-Compliant (Manual/MPM)" "MPM" (@($biz|?{$_.ComplianceStatus -eq "Non-Compliant" -and -not $_.AutoManaged}).Count)
Add-M "Non-Compliant (Auto/APM)" "APM" (@($biz|?{$_.ComplianceStatus -eq "Non-Compliant" -and $_.AutoManaged}).Count)
Add-M "Pending First Management" "All" (@($biz|?{$_.ComplianceStatus -eq "Pending/Unknown"}).Count)
foreach($g in $biz | Group-Object VerifyStatus){ Add-M "Verification Status" $g.Name $g.Count }
Add-M "Rotation Overdue" "All" (@($biz|?{$_.RotationOverdue}).Count)
foreach($g in ($biz|?{$_.RotationOverdue} | Group-Object Region)){ Add-M "Rotation Overdue by Region" $g.Name $g.Count }
foreach($g in ($biz|?{$_.RotationOverdue} | Group-Object Tier)){ Add-M "Rotation Overdue by Tier" $g.Name $g.Count }
foreach($g in ($biz|?{$_.RotationOverdue} | Group-Object OSCategory)){ Add-M "Rotation Overdue by OS" $g.Name $g.Count }
Add-M "Stale Accounts (No Change >= $StaleAccountDays d)" "All" (@($biz|?{$_.IsStale}).Count)
Add-M "Verification Overdue" "All" (@($biz|?{$_.VerifyStatus -like 'Overdue*'}).Count)
Add-M "Never Verified (Auto-Managed)" "All" (@($biz|?{$_.VerifyStatus -eq 'Never Verified'}).Count)

# ── STEP 7 : ONBOARDING TREND (last $TrendLookbackMonths months) ────────────────
Write-Log "Building onboarding trend (last $TrendLookbackMonths months)..." SECTION
$trendCutoff = [datetime]::new((Get-Date).AddMonths(-1 * $TrendLookbackMonths).Year, (Get-Date).AddMonths(-1 * $TrendLookbackMonths).Month, 1)

$acctTrend = $biz | ?{ $_.CreatedMonth -and ([datetime]::ParseExact("$($_.CreatedMonth)-01","yyyy-MM-dd",$null) -ge $trendCutoff) } |
    Group-Object CreatedMonth | Sort-Object Name
foreach($g in $acctTrend){ Add-M "Accounts Onboarded by Month" $g.Name $g.Count }

$safeTrend = $bizSafes | ?{ $_.CreatedDate -and ([datetime]$_.CreatedDate -ge $trendCutoff) } |
    ForEach-Object { [pscustomobject]@{ Month = ([datetime]$_.CreatedDate).ToString("yyyy-MM") } } |
    Group-Object Month | Sort-Object Name
foreach($g in $safeTrend){ Add-M "Safes Onboarded by Month" $g.Name $g.Count }

Add-M "Accounts Recently Onboarded (<= $OnboardingWindowDays d)" "All" (@($biz|?{$_.RecentlyOnboarded}).Count)
Add-M "Safes Recently Created (<= $OnboardingWindowDays d)" "All" (@($bizSafes|?{$_.RecentlyCreated}).Count)

# ── STEP 8 : SAFE MEMBERS (optional - 1 call per safe, sequential) ──────────────
$MembersRaw = @()
if ($CollectSafeMembers) {
    Write-Log "Collecting Safe Members for $($SafeFact.Count) safes (sequential)..." SECTION
    $memberSw = [System.Diagnostics.Stopwatch]::StartNew()

    $MembersRaw = @(foreach ($sn in $SafeFact.SafeName) { Get-SafeMembersForSafe -SafeName $sn })

    $memberSw.Stop()
    Write-Log "Safe Members collected: $($MembersRaw.Count) rows in $([Math]::Round($memberSw.Elapsed.TotalSeconds,1))s" SUCCESS

    # RAW (readable): raw member details. INFO: criteria-based classification.
    $MembersRaw | Select-Object SafeName,MemberName,MemberID,MemberType,IsPredefinedUser,IsReadOnly,MembershipExpirationDate,Permissions |
        Export-Csv "$OutputDir\SafeMembers_Raw.csv" -NoTypeInformation -Encoding UTF8
    $MembersRaw | Select-Object SafeName,MemberName,MemberType,IsDefaultMember,Permissions |
        Export-Csv "$OutputDir\SafeMembers_Info.csv" -NoTypeInformation -Encoding UTF8

    $bizMembers = @($MembersRaw | ?{ -not (Test-IsDefaultSafe $_.SafeName) })
    foreach($g in $bizMembers | Group-Object MemberType){ Add-M "Safe Members by Type" $g.Name $g.Count }
    $safesWithMembers = $bizMembers | Group-Object SafeName | Select-Object -Expand Name
    $orphanSafes = @($bizSafes | ?{ $safesWithMembers -notcontains $_.SafeName })
    Add-M "Safes With No Members Found" "All" $orphanSafes.Count
} else {
    Write-Log "CollectSafeMembers=`$false - skipping Safe Members stage (1 call/safe). Set `$CollectSafeMembers=`$true to enable." WARN
}

# ── STEP 9 : EXPORT + CONSOLE SUMMARY ───────────────────────────────────────────
$rows | Export-Csv "$OutputDir\Metrics_Summary.csv" -NoTypeInformation -Encoding UTF8
Write-Log "Metrics summary rows: $($rows.Count)" SUCCESS

$Divider = "=" * 75
Write-Host ""
Write-Host $Divider -ForegroundColor White
Write-Host "  CYBERARK OPERATIONAL METRICS - RUN SUMMARY" -ForegroundColor White
Write-Host $Divider -ForegroundColor White
Write-Host ("  Safes               : {0} (business: {1})" -f $SafesRaw.Count, $bizSafes.Count) -ForegroundColor White
Write-Host ("  Users               : {0} (real: {1})" -f $UsersRaw.Count, $realUsers.Count) -ForegroundColor White
Write-Host ("  Groups              : {0}" -f $GroupsRaw.Count) -ForegroundColor White
Write-Host ("  Platforms           : {0}" -f $PlatRaw.Count) -ForegroundColor White
Write-Host ("  Accounts            : {0} (business: {1})" -f $AcctRaw.Count, $biz.Count) -ForegroundColor White
if ($CollectSafeMembers) {
    Write-Host ("  Safe Members        : {0}" -f @($MembersRaw).Count) -ForegroundColor White
}
Write-Host ("  Metrics Rows        : {0}" -f $rows.Count) -ForegroundColor Green
Write-Host ("  Output              : {0}" -f $OutputDir) -ForegroundColor Green
Write-Host $Divider -ForegroundColor White

Write-Log "=== CyberArk Operational Metrics Export Complete ===" SECTION
