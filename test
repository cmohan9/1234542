Add-M "Accounts Recently Onboarded (<= $OnboardingWindowDays d)" "All" (@($biz|?{$_.RecentlyOnboarded}).Count)
Add-M "Safes Recently Created (<= $OnboardingWindowDays d)" "All" (@($bizSafes|?{$_.RecentlyCreated}).Count)

# ── STEP 8 : SAFE MEMBERS (optional - 1 call per safe; parallel on PS7+) ────────
$MembersRaw = @()
if ($CollectSafeMembers) {
    Write-Log "Collecting Safe Members for $($SafeFact.Count) safes (parallel: $IsPS7Plus, throttle: $ParallelThrottleLimit)..." SECTION
    $memberSw = [System.Diagnostics.Stopwatch]::StartNew()

    if ($IsPS7Plus) {
        # Re-authenticate right before fanning out so every thread starts with
        # a fresh token, then seed each parallel runspace with a copy of it -
        # runspaces don't share $Global: state, so without this every thread
        # would otherwise have to authenticate independently on its first call.
        Get-AuthToken
        $SeedToken  = $Global:Token
        $SeedExpiry = $Global:TokenExpiry

        # ForEach-Object -Parallel runspaces don't inherit functions from the
        # calling scope either - only variables, and only via $using:. So each
        # function this stage needs is captured as a string here and
        # reconstructed with `${function:Name} = $using:...` inside the block.
        $fnAuthToken  = ${function:Get-AuthToken}.ToString()
        $fnHeaders    = ${function:Get-Headers}.ToString()
        $fnApiGet     = ${function:Invoke-ApiGet}.ToString()
        $fnDefaultMbr = ${function:Test-IsDefaultMember}.ToString()
        $fnGetMembers = ${function:Get-SafeMembersForSafe}.ToString()
        $fnWriteLog   = ${function:Write-Log}.ToString()

        # Select-Object -ExpandProperty (not $SafeFact.SafeName) is required
        # here: member-enumeration shorthand on an EMPTY array evaluates to a
        # bare $null, and @($null) is a 1-element array containing $null, not
        # an empty one - piping that into ForEach-Object -Parallel would run
        # the block once with $_ = $null instead of zero times. Expand-Property
        # runs per pipeline item, so zero input genuinely means zero output.
        $safeNames = @($SafeFact | Select-Object -ExpandProperty SafeName)

        $MembersRaw = $safeNames | ForEach-Object -Parallel {
            ${function:Write-Log}              = $using:fnWriteLog
            ${function:Get-AuthToken}          = $using:fnAuthToken
            ${function:Get-Headers}            = $using:fnHeaders
            ${function:Invoke-ApiGet}          = $using:fnApiGet
            ${function:Test-IsDefaultMember}   = $using:fnDefaultMbr
            ${function:Get-SafeMembersForSafe} = $using:fnGetMembers

            $IdentityUrl            = $using:IdentityUrl
            $ServiceUserId          = $using:ServiceUserId
            $ServiceUserSecret      = $using:ServiceUserSecret
            $PvwaBase               = $using:PvwaBase
            $PageLimit              = $using:PageLimit
            $MaxRetries             = $using:MaxRetries
            $RetryWaitSeconds       = $using:RetryWaitSeconds
            $DefaultMembersPatterns = $using:DefaultMembersPatterns
            $LogFile                = $using:LogFile

            $Global:Token       = $using:SeedToken
            $Global:TokenExpiry = $using:SeedExpiry

            Get-SafeMembersForSafe -SafeName $_
        } -ThrottleLimit $ParallelThrottleLimit
    } else {
        $MembersRaw = foreach ($sn in $SafeFact.SafeName) { Get-SafeMembersForSafe -SafeName $sn }
    }

    $memberSw.Stop()
    $MembersRaw = @($MembersRaw)
    Write-Log "Safe Members collected: $($MembersRaw.Count) rows in $([Math]::Round($memberSw.Elapsed.TotalSeconds,1))s" SUCCESS
    $MembersRaw | Export-Csv "$OutputDir\SafeMembers_Fact.csv" -NoTypeInformation -Encoding UTF8

    $bizMembers = @($MembersRaw | ?{ -not (Test-IsDefaultSafe $_.SafeName) })
    foreach($g in $bizMembers | Group-Object MemberType){ Add-M "Safe Members by Type" $g.Name $g.Count }
    $safesWithMembers = $bizMembers | Group-Object SafeName | Select-Object -Expand Name
    $orphanSafes = @($bizSafes | ?{ $safesWithMembers -notcontains $_.SafeName })
    Add-M "Safes With No Members Found" "All" $orphanSafes.Count
} else {
    Write-Log "CollectSafeMembers=`$false - skipping Safe Members stage (1 call/safe). Set `$CollectSafeMembers=`$true to enable." WARN
}

# ── STEP 9 : EXPORT + CONSOLE SUMMARY ───────────────────────────────────────────
$rows | Export-Csv "$OutputDir\Metrics_Summary.csv" -NoTypeInformation -Encoding UTF8
Write-Log "Metrics summary rows: $($rows.Count)" SUCCESS

$Divider = "=" * 75
Write-Host ""
Write-Host $Divider -ForegroundColor White
Write-Host "  CYBERARK OPERATIONAL METRICS - RUN SUMMARY" -ForegroundColor White
Write-Host $Divider -ForegroundColor White
Write-Host ("  Safes               : {0} (business: {1})" -f $SafesRaw.Count, $bizSafes.Count) -ForegroundColor White
Write-Host ("  Users               : {0} (real: {1})" -f $UsersRaw.Count, $realUsers.Count) -ForegroundColor White
Write-Host ("  Groups              : {0}" -f $GroupsRaw.Count) -ForegroundColor White
Write-Host ("  Platforms           : {0}" -f $PlatRaw.Count) -ForegroundColor White
Write-Host ("  Accounts            : {0} (business: {1})" -f $AcctRaw.Count, $biz.Count) -ForegroundColor White
if ($CollectSafeMembers) {
    Write-Host ("  Safe Members        : {0}" -f @($MembersRaw).Count) -ForegroundColor White
}
Write-Host ("  Metrics Rows        : {0}" -f $rows.Count) -ForegroundColor Green
Write-Host ("  Output              : {0}" -f $OutputDir) -ForegroundColor Green
Write-Host $Divider -ForegroundColor White

Write-Log "=== CyberArk Operational Metrics Export Complete ===" SECTION
