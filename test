$UsersResp = Invoke-ApiGet -Uri "$PvwaBase/Users?ExtendedDetails=True"
$UsersRaw  = if($UsersResp.Users){$UsersResp.Users}else{@()}

# RAW (readable): flatten each fetched User, epoch -> real date.
$UsersRawOut = @(foreach($u in $UsersRaw){
    [pscustomobject]@{
        UserName                = $u.username
        UserID                  = $u.id
        Source                  = $u.source
        UserType                = $u.userType
        ComponentUser           = $u.componentUser
        Enabled                 = $u.enableUser
        Suspended               = $u.suspended
        Location                = $u.location
        PasswordNeverExpires    = $u.passwordNeverExpires
        FirstName               = $u.personalDetails.firstName
        LastName                = $u.personalDetails.lastName
        BusinessEmail           = $u.internet.businessEmail
        VaultAuthorization      = ($u.vaultAuthorization -join "; ")
        LastSuccessfulLoginDate = Format-DateTime (ConvertFrom-Unix $u.lastSuccessfulLoginDate)
    }
})
$UsersRawOut | Export-Csv "$OutputDir\Users_Raw.csv" -NoTypeInformation -Encoding UTF8

$UserFact = @(foreach($u in $UsersRaw){
    $isComp = ($u.componentUser -eq $true) -or (Test-IsDefaultMember $u.username) -or ($u.userType -ne "EPVUser")
    $lastLogin = ConvertFrom-Unix $u.lastSuccessfulLoginDate
    $days = if($lastLogin){(New-TimeSpan -Start $lastLogin -End (Get-Date)).Days}else{$null}
    [pscustomobject]@{
        UserName      = $u.username
        UserType      = $u.userType
        IsComponent   = $isComp
        Enabled       = $u.enableUser
        LastLoginDate = if($lastLogin){$lastLogin.ToString("yyyy-MM-dd")}else{"Never"}
        DaysSinceLogin= $days
        LoginStatus   = if(-not $lastLogin){"Never Logged In"}
                        elseif($days -le $LoginWindowDays){"Active (<= $LoginWindowDays d)"}
                        else{"Dormant (> $LoginWindowDays d)"}
    }
})
$UserFact | Export-Csv "$OutputDir\Users_Info.csv" -NoTypeInformation -Encoding UTF8
$realUsers = @($UserFact | ?{ -not $_.IsComponent })
Write-Log "Users: total=$($UsersRaw.Count) real=$($realUsers.Count) active=$(@($realUsers|?{$_.LoginStatus -like 'Active*'}).Count)" SUCCESS

