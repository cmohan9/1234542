Write-Host "Filtered accounts: $($AcctSearch.value.Count)" -ForegroundColor Cyan
$AcctSearch.value[0..1] | ConvertTo-Json -Depth 10
#endregion

#region ===== BLOCK 11 : ACCOUNT DETAILS ==================================
