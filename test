        NumberOfDaysRetention     = $s.numberOfDaysRetention
        CreationTime              = Format-DateTime (ConvertFrom-Unix      $s.creationTime)
        LastModificationTime      = Format-DateTime (ConvertFrom-UnixMicro $s.lastModificationTime)
    }
})
$SafesRawOut | Export-Csv "$OutputDir\Safes_Raw.csv" -NoTypeInformation -Encoding UTF8

$SafeFact = @(foreach($s in $SafesRaw){
    $def = Test-IsDefaultSafe $s.safeName
    $created = ConvertFrom-Unix $s.creationTime
    [pscustomobject]@{
        SafeName      = $s.safeName
