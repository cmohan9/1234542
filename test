Write-Log "=== Step 2: Collecting Safes ===" SECTION
$SafesRaw = Get-AllPaged -BaseUri "$PvwaBase/Safes" -ValueProp "value"

$DimSafe = @(foreach ($s in $SafesRaw) {
    $def = Test-IsDefaultSafe $s.safeName
    $created = ConvertFrom-Unix $s.creationTime
    $lastMod = ConvertFrom-UnixMicro $s.lastModificationTime
    $namingOk = if ($def) { $true } else { Test-SafeNaming $s.safeName }
    $safeType = Get-SafeType $s.safeName $def
    [pscustomobject]@{
        SafeName      = $s.safeName
        SafeUrlId     = $s.safeUrlId
        SafeNumber    = $s.safeNumber
        Description   = Safe-String $s.description
        Location      = Safe-String $s.location
        Creator       = Safe-String $s.creator.name
        ManagingCPM   = Safe-String $s.managingCPM
        NumberOfAccounts = [int]$s.numberOfAccounts
        OLACEnabled   = $s.olacEnabled
        AutoPurge     = $s.autoPurgeEnabled
        RetentionVersions = $s.numberOfVersionsRetention
        RetentionDays = $s.numberOfDaysRetention
        CreatedDate   = Format-DateOnly $created
        CreatedDateTime = Format-DateTime $created
        LastModifiedDateTime = Format-DateTime $lastMod
        IsDefault     = $def
        SafeType      = $safeType
        Region        = if ($def) { "N/A-Default" } else { Get-Region $s.safeName }
        Tier          = if ($def) { "N/A-Default" } else { Get-SafeTier $s.safeName $safeType }
        HasCPM        = -not [string]::IsNullOrWhiteSpace($s.managingCPM)
        IsEmpty       = ([int]$s.numberOfAccounts -eq 0)
        RecentlyCreated = ($created -and (New-TimeSpan -Start $created -End (Get-Date)).Days -le $OnboardingWindowDays)
        NamingCompliant = $namingOk
        ExtractDate   = $ExtractDate
    }
})

$SafeLookup = @{}; foreach ($f in $DimSafe) { $SafeLookup[$f.SafeName] = $f }
$bizSafes = @($DimSafe | Where-Object { -not $_.IsDefault })
Write-Log "Safes: total=$($SafesRaw.Count) business=$($bizSafes.Count) default=$($DimSafe.Count - $bizSafes.Count)" SUCCESS
$RecordCounts["DIM_Safe"] = $DimSafe.Count

# ══════════════════════════════════════════════════════════════════════════════
#  STEP 3 : USERS → FACT_Users.csv
# ══════════════════════════════════════════════════════════════════════════════
Write-Log "=== Step 3: Collecting Users ===" SECTION
$UsersResp = Invoke-ApiGet -Uri "$PvwaBase/Users?ExtendedDetails=True"
$UsersRaw  = if ($UsersResp.Users) { $UsersResp.Users } else { @() }

$FactUsers = @(foreach ($u in $UsersRaw) {
    $isComp = ($u.componentUser -eq $true) -or (Test-IsDefaultMember $u.username) -or ($u.userType -ne "EPVUser")
    $lastLogin = ConvertFrom-Unix $u.lastSuccessfulLoginDate
    $days = if ($lastLogin) { (New-TimeSpan -Start $lastLogin -End (Get-Date)).Days } else { $null }
    [pscustomobject]@{
        UserName       = $u.username
        UserID         = $u.id
        Source         = Safe-String $u.source
        UserType       = $u.userType
        ComponentUser  = $u.componentUser
        IsComponent    = $isComp
        Enabled        = $u.enableUser
        Suspended      = $u.suspended
        Location       = Safe-String $u.location
        FirstName      = Safe-String $u.personalDetails.firstName
        LastName       = Safe-String $u.personalDetails.lastName
        Email          = Safe-String $u.internet.businessEmail
        VaultAuth      = (($u.vaultAuthorization) -join "; ")
        PasswordNeverExpires = $u.passwordNeverExpires
        LastLoginDate  = Format-DateOnly $lastLogin
        LastLoginDateTime = Format-DateTime $lastLogin
        DaysSinceLogin = $days
        LoginStatus    = if (-not $lastLogin) { "Never Logged In" }
                         elseif ($days -le $LoginWindowDays) { "Active (<= $LoginWindowDays d)" }
                         else { "Dormant (> $LoginWindowDays d)" }
        ExtractDate    = $ExtractDate
    }
})

$realUsers = @($FactUsers | Where-Object { -not $_.IsComponent })
Write-Log "Users: total=$($UsersRaw.Count) real=$($realUsers.Count) active=$(@($realUsers | Where-Object { $_.LoginStatus -like 'Active*' }).Count)" SUCCESS
$RecordCounts["FACT_Users"] = $FactUsers.Count

# ══════════════════════════════════════════════════════════════════════════════
#  STEP 4 : GROUPS → FACT_Groups.csv
# ══════════════════════════════════════════════════════════════════════════════
Write-Log "=== Step 4: Collecting Groups ===" SECTION
$GroupsResp = Invoke-ApiGet -Uri "$PvwaBase/UserGroups"
$GroupsRaw  = if ($GroupsResp.value) { $GroupsResp.value } else { @() }

$FactGroups = @(foreach ($g in $GroupsRaw) {
    [pscustomobject]@{
        GroupName  = $g.groupName
        GroupID    = $g.id
        GroupType  = $g.groupType
        Directory  = Safe-String $g.directory
        Location   = Safe-String $g.location
        IsDefault  = Test-IsDefaultGroup $g.groupName
        ExtractDate = $ExtractDate
    }
})
Write-Log "Groups: total=$($GroupsRaw.Count)" SUCCESS
$RecordCounts["FACT_Groups"] = $FactGroups.Count

# ══════════════════════════════════════════════════════════════════════════════
#  STEP 5 : PLATFORMS → DIM_Platform.csv
# ══════════════════════════════════════════════════════════════════════════════
Write-Log "=== Step 5: Collecting Platforms ===" SECTION
$PlatResp = Invoke-ApiGet -Uri "$PvwaBase/Platforms"
$PlatRaw  = if ($PlatResp.Platforms) { $PlatResp.Platforms } else { @() }

$DimPlatform = @(foreach ($p in $PlatRaw) {
    $platId = Safe-String $p.general.id
    [pscustomobject]@{
        PlatformID     = $platId
        PlatformName   = Safe-String $p.general.name
        SystemType     = Safe-String $p.general.systemType
        Active         = $p.general.active
        PlatformBaseID = Safe-String $p.general.platformBaseID
        PlatformType   = Safe-String $p.general.platformType
        OSCategory     = Get-OSCategory $platId
        RotationDays   = Get-RotationDays $platId
        ExtractDate    = $ExtractDate
    }
})
Write-Log "Platforms: total=$($PlatRaw.Count) active=$(@($DimPlatform | Where-Object { $_.Active }).Count)" SUCCESS
$RecordCounts["DIM_Platform"] = $DimPlatform.Count

# ══════════════════════════════════════════════════════════════════════════════
#  STEP 6 : ACCOUNTS → FACT_Accounts.csv + FACT_CPMFailed.csv + FACT_PlatformSummary.csv
# ══════════════════════════════════════════════════════════════════════════════
Write-Log "=== Step 6: Collecting Accounts ===" SECTION
$AcctRaw = Get-AllPaged -BaseUri "$PvwaBase/Accounts" -ValueProp "value"

$PlatformStats = @{}
$CPMFailedRows = [System.Collections.Generic.List[PSCustomObject]]::new()

$FactAccounts = @(foreach ($a in $AcctRaw) {
    $sfi      = $SafeLookup[$a.safeName]
    $defSafe  = if ($sfi) { $sfi.IsDefault } else { Test-IsDefaultSafe $a.safeName }
    $sm       = $a.secretManagement
    $auto     = ($sm.automaticManagementEnabled -eq $true)
    $lastChg  = ConvertFrom-Unix $sm.lastModifiedTime
    $lastVer  = ConvertFrom-Unix $sm.lastVerifiedTime
    $lastRec  = ConvertFrom-Unix $sm.lastReconciledTime
    $created  = ConvertFrom-Unix $a.createdTime
    $dChg     = if ($lastChg) { (New-TimeSpan -Start $lastChg -End (Get-Date)).Days } else { $null }
    $dVer     = if ($lastVer) { (New-TimeSpan -Start $lastVer -End (Get-Date)).Days } else { $null }
    $dAge     = if ($created) { (New-TimeSpan -Start $created -End (Get-Date)).Days } else { $null }
    $rot      = Get-RotationDays $a.platformId
    $cpmStat  = Safe-String $sm.status
    $comp     = switch ($cpmStat) { "success" { "Compliant" } "failure" { "Non-Compliant" } default { "Pending/Unknown" } }
    $safeType = if ($sfi) { $sfi.SafeType } else { Get-SafeType $a.safeName $defSafe }
    $region   = if ($sfi) { $sfi.Region } else { Get-Region $a.safeName }
    $tier     = if ($sfi) { $sfi.Tier }   else { Get-SafeTier $a.safeName $safeType }
    $platId   = Safe-String $a.platformId "Unknown"
    $nameOk   = Test-AccountNaming (Safe-String $a.name)
    $addrOk   = Test-AccountAddress (Safe-String $a.address)

    # Platform aggregation
    if (-not $PlatformStats.ContainsKey($platId)) {
        $PlatformStats[$platId] = @{ Total=0; Managed=0; Unmanaged=0; Success=0; Failed=0 }
    }
    $PlatformStats[$platId].Total++
    if ($auto) {
        $PlatformStats[$platId].Managed++
        if ($cpmStat -eq "success") { $PlatformStats[$platId].Success++ }
        elseif ($cpmStat -ne "" -and $null -ne $cpmStat) { $PlatformStats[$platId].Failed++ }
    } else { $PlatformStats[$platId].Unmanaged++ }

    # CPM Failed
    if ($auto -and $cpmStat -ne "success" -and $cpmStat -ne "" -and $null -ne $cpmStat) {
        $CPMFailedRows.Add([pscustomobject]@{
            AccountID    = Safe-String $a.id
            AccountName  = Safe-String $a.userName
            Address      = Safe-String $a.address
            PlatformID   = $platId
            SafeName     = Safe-String $a.safeName
            Region       = $region
            Tier         = $tier
            CPMStatus    = $cpmStat
            ManualReason = Safe-String $sm.manualManagementReason
            LastModified = Format-DateTime $lastChg
            LastVerified = Format-DateTime $lastVer
            LastReconciled = Format-DateTime $lastRec
            CreatedDate  = Format-DateOnly $created
            ExtractDate  = $ExtractDate
        })
    }

    [pscustomobject]@{
        AccountID         = Safe-String $a.id
        Name              = Safe-String $a.name
        UserName          = Safe-String $a.userName
        Address           = Safe-String $a.address
        SafeName          = Safe-String $a.safeName
        PlatformID        = $platId
        SecretType        = Safe-String $a.secretType
        IsDefaultSafe     = $defSafe
        SafeType          = $safeType
        Region            = $region
        Tier              = $tier
        OSCategory        = Get-OSCategory $platId
        AutoManaged       = $auto
        MgmtTechnique     = if ($auto) { "Automatic (APM)" } else { "Manual (MPM)" }
        ManualReason      = Safe-String $sm.manualManagementReason
        ComplianceStatus  = $comp
        SecretStatus      = $cpmStat
        LastChangeDate    = Format-DateOnly $lastChg
        LastChangeDateTime = Format-DateTime $lastChg
        DaysSinceChange   = $dChg
        ExpectedRotationDays = $rot
        RotationOverdue   = if ($null -ne $dChg) { $dChg -gt $rot } else { $false }
        LastVerifyDate    = Format-DateOnly $lastVer
        DaysSinceVerify   = $dVer
        VerifyStatus      = if (-not $auto) { "N/A (Manual)" }
                            elseif (-not $lastVer) { "Never Verified" }
                            elseif ($dVer -gt $VerifyOverdueDays) { "Overdue (> $VerifyOverdueDays d)" }
                            else { "OK" }
        LastReconciledDate = Format-DateOnly $lastRec
        IsStale           = if ($null -ne $dChg) { $dChg -ge $StaleAccountDays } else { $false }
        CreatedDate       = Format-DateOnly $created
        CreatedMonth      = Format-MonthOnly $created
        AccountAgeDays    = $dAge
        RecentlyOnboarded = ($created -and (New-TimeSpan -Start $created -End (Get-Date)).Days -le $OnboardingWindowDays)
        NameCompliant     = $nameOk
        AddressCompliant  = $addrOk
        HasAddress        = -not [string]::IsNullOrWhiteSpace($a.address)
        ExtractDate       = $ExtractDate
    }
})

$biz = @($FactAccounts | Where-Object { -not $_.IsDefaultSafe })
Write-Log "Accounts: total=$($AcctRaw.Count) business=$($biz.Count)" SUCCESS
Write-Log "CPM failed/pending: $($CPMFailedRows.Count)" $(if ($CPMFailedRows.Count -gt 0) { "WARN" } else { "SUCCESS" })
$RecordCounts["FACT_Accounts"] = $FactAccounts.Count
$RecordCounts["FACT_CPMFailed"] = $CPMFailedRows.Count

# Build FACT_PlatformSummary
$usedPlats = $biz | Group-Object PlatformID | Select-Object -ExpandProperty Name
$FactPlatformSummary = @(foreach ($pk in ($PlatformStats.Keys | Sort-Object)) {
    $ps = $PlatformStats[$pk]
    [pscustomobject]@{
        PlatformID     = $pk
        TotalAccounts  = $ps.Total
        ManagedCount   = $ps.Managed
        UnmanagedCount = $ps.Unmanaged
        SuccessCount   = $ps.Success
        FailedCount    = $ps.Failed
        ManagedPct     = if ($ps.Total -gt 0) { [math]::Round(($ps.Managed / $ps.Total) * 100, 1) } else { 0 }
        SuccessRatePct = if ($ps.Managed -gt 0) { [math]::Round(($ps.Success / $ps.Managed) * 100, 1) } else { 0 }
        IsUsed         = ($usedPlats -contains $pk)
        ExtractDate    = $ExtractDate
    }
})
$RecordCounts["FACT_PlatformSummary"] = $FactPlatformSummary.Count

# ══════════════════════════════════════════════════════════════════════════════
#  STEP 7 : VAULT CONNECTIVITY → FACT_VaultConnectivity.csv
# ══════════════════════════════════════════════════════════════════════════════
Write-Log "=== Step 7: Fetching Vault Connectivity ===" SECTION
$VaultRows = [System.Collections.Generic.List[PSCustomObject]]::new()
foreach ($compType in $VaultComponentIDs) {
    try {
        $vResp = Invoke-ApiGet -Uri "$PvwaBase/ComponentsMonitoringDetails/$compType/"
        if ($null -ne $vResp -and $null -ne $vResp.ComponentsDetails) {
            foreach ($d in $vResp.ComponentsDetails) {
                $VaultRows.Add([pscustomobject]@{
                    ComponentType    = $compType
                    InstanceIP       = Safe-String $d.ComponentIP
                    VaultUserName    = Safe-String $d.ComponentUserName
                    ComponentVersion = Safe-String $d.ComponentVersion
                    IsLoggedOn       = if ($d.IsLoggedOn -eq $true) { "TRUE" } else { "FALSE" }
                    LastLogonDate    = Format-DateTime (ConvertFrom-Unix $d.LastLogonDate)
                    ExtractDate      = $ExtractDate
                })
            }
            Write-Log "  $compType instances: $($vResp.ComponentsDetails.Count)" INFO
        }
    } catch {
        Write-Log "Failed vault details for ${compType}: $($_.Exception.Message)" ERROR
        $RunErrors.Add("VaultConnectivity ($compType): $($_.Exception.Message)")
    }
}
Write-Log "Vault connectivity records: $($VaultRows.Count)" SUCCESS
$RecordCounts["FACT_VaultConnectivity"] = $VaultRows.Count


# ══════════════════════════════════════════════════════════════════════════════
#  STEP 13 : SAFE MEMBERS + ADMIN/BREAKGLASS AUDIT → FACT_SafeMembers.csv +
#            FACT_AdminAudit.csv (opt-in)
# ══════════════════════════════════════════════════════════════════════════════
$MemberRows  = [System.Collections.Generic.List[PSCustomObject]]::new()
$AdminAuditRows = [System.Collections.Generic.List[PSCustomObject]]::new()

if ($CollectSafeMembers) {
    Write-Log "=== Step 13: Collecting Safe Members + Admin/Breakglass Audit ===" SECTION
    $memberSw = [System.Diagnostics.Stopwatch]::StartNew()
    $safeIdx  = 0

    foreach ($sf in $DimSafe) {
        $safeName = $sf.SafeName
        $safeIdx++
        if ($safeIdx % 50 -eq 0) { Write-Log "  Processing safe $safeIdx / $($DimSafe.Count)..." INFO }

        # Fetch members
        $urlSeg = Get-SafeMemberUrl $safeName
        $allMembers = @(); $mOff = 0
        do {
            $mResp = Invoke-ApiGet -Uri "$PvwaBase/Safes/$urlSeg/Members?limit=$PageLimit&offset=$mOff&includePredefinedUsers=true"
            if (-not $mResp) { break }
            $mBatch = $mResp.value
            if (-not $mBatch) { break }
            $allMembers += $mBatch; $mOff += $PageLimit
        } while ($mBatch.Count -eq $PageLimit)

        $foundAuditGroups = @{}
        foreach ($ag in $AuditGroups) { $foundAuditGroups[$ag] = $null }

        foreach ($m in $allMembers) {
            $mName = $m.memberName
            $mType = $m.memberType
            $perms = $m.permissions
            $isDef = Test-IsDefaultMember $mName

            # Safe Manager check (retained for the IsSafeManager column on FACT_SafeMembers)
            $isMgr = $true
            foreach ($p in $SafeManagerCheckPermissions) {
                if ($perms.$p -ne $true) { $isMgr = $false; break }
            }

            # Member category
            $cat = "Standard"
            if ($sf.IsDefault -or $isDef) { $cat = "DefaultSystem" }
            elseif ($AuditGroups -contains $mName) { $cat = "AuditedAdminBG" }

            # Audit group tracking
            if ($AuditGroups -contains $mName) { $foundAuditGroups[$mName] = $perms }

            # Build permission columns
            $permHash = [ordered]@{}
            foreach ($p in $AllPermissions) { $permHash[$p] = if ($perms.$p -eq $true) { "TRUE" } else { "FALSE" } }

            $MemberRows.Add([pscustomobject]@{
                SafeName     = $safeName
                IsDefaultSafe = $sf.IsDefault
                Region       = $sf.Region
                Tier         = $sf.Tier
                MemberName   = $mName
                MemberID     = $m.memberId
                MemberType   = $mType
                IsDefaultMember = $isDef
                IsSafeManager   = $isMgr
                MemberCategory  = $cat
                IsPredefinedUser = $m.isPredefinedUser
                IsReadOnly      = $m.isReadOnly
                MembershipExpirationDate = Format-DateTime (ConvertFrom-Unix $m.membershipExpirationDate)
                Permissions     = ($permHash.GetEnumerator() | Where-Object { $_.Value -eq "TRUE" } | ForEach-Object { $_.Key }) -join "; "
                ExtractDate     = $ExtractDate
            })
        }

        # Safe-level admin/breakglass audit (business safes only)
        if (-not $sf.IsDefault) {
            # Admin/BG Audit
            foreach ($ag in $AuditGroups) {
                $gp = $foundAuditGroups[$ag]
                if ($null -eq $gp) {
                    $AdminAuditRows.Add([pscustomobject]@{
                        SafeName=$safeName; IsDefaultSafe=$sf.IsDefault; Region=$sf.Region; Tier=$sf.Tier
                        GroupName=$ag; GroupExists="No"; PermissionLevel="None"; MissingPermissions="All"
                        ExtractDate=$ExtractDate
                    })
                } else {
                    $miss = @()
                    foreach ($p in $FullAccessCheckPermissions) { if ($gp.$p -ne $true) { $miss += $p } }
                    $AdminAuditRows.Add([pscustomobject]@{
                        SafeName=$safeName; IsDefaultSafe=$sf.IsDefault; Region=$sf.Region; Tier=$sf.Tier
                        GroupName=$ag; GroupExists="Yes"
                        PermissionLevel = if ($miss.Count -eq 0) { "Full" } else { "Partial" }
                        MissingPermissions = if ($miss.Count -eq 0) { "" } else { $miss -join " | " }
                        ExtractDate=$ExtractDate
                    })
                }
            }
        }
    }

    $memberSw.Stop()
    Write-Log "Safe Members: $($MemberRows.Count) rows in $([Math]::Round($memberSw.Elapsed.TotalSeconds,1))s" SUCCESS
    Write-Log "Admin Audit: $($AdminAuditRows.Count)" SUCCESS
} else {
    Write-Log "=== Step 13: Safe Members + Admin Audit SKIPPED (opt-in off) ===" SECTION
    Write-Log "  Set `$CollectSafeMembers=`$true to enable (1 API call per safe)." WARN
}
$RecordCounts["FACT_SafeMembers"] = $MemberRows.Count
$RecordCounts["FACT_AdminAudit"] = $AdminAuditRows.Count



# ══════════════════════════════════════════════════════════════════════════════
#  STEP 15 : METRICS SUMMARY → FACT_MetricsSummary.csv
# ══════════════════════════════════════════════════════════════════════════════
Write-Log "=== Step 15: Building Metrics Summary ===" SECTION

# Inventory
foreach ($g in $bizSafes | Group-Object Region)   { Add-Metric "Safes by Region" $g.Name $g.Count }
foreach ($g in $bizSafes | Group-Object Tier)     { Add-Metric "Safes by Tier" $g.Name $g.Count }
foreach ($g in $bizSafes | Group-Object SafeType) { Add-Metric "Safes by SafeType" $g.Name $g.Count }
foreach ($g in $biz | Group-Object SafeType)      { Add-Metric "Accounts by SafeType" $g.Name $g.Count }
Add-Metric "Platforms Total" "All" $DimPlatform.Count
Add-Metric "Platforms Active" "Active" (@($DimPlatform | Where-Object { $_.Active }).Count)
Add-Metric "Platforms Defined-but-Unused" "All" (@($FactPlatformSummary | Where-Object { -not $_.IsUsed }).Count)
Add-Metric "Empty Safes" "All" (@($bizSafes | Where-Object { $_.IsEmpty }).Count)
Add-Metric "Safes without CPM" "All" (@($bizSafes | Where-Object { -not $_.HasCPM }).Count)
Add-Metric "Non-standard Safe Names" "All" (@($bizSafes | Where-Object { -not $_.NamingCompliant }).Count)
$bizSafes | Sort-Object NumberOfAccounts -Descending | Select-Object -First $TopNSafes |
    ForEach-Object { Add-Metric "Top Safes by Accounts" $_.SafeName $_.NumberOfAccounts }

# Region x Tier
foreach ($g in $biz | Group-Object Region,Tier) { Add-Metric "Accounts Region x Tier" $g.Name $g.Count }

# OS Categories
foreach ($g in $biz | Group-Object OSCategory) { Add-Metric "Accounts by OS" $g.Name $g.Count }

# Health
Add-Metric "Total Business Accounts" "All" $biz.Count
Add-Metric "Failed Accounts (Total)" "All" (@($biz | Where-Object { $_.ComplianceStatus -eq "Non-Compliant" }).Count)
foreach ($g in ($biz | Where-Object { $_.ComplianceStatus -eq "Non-Compliant" } | Group-Object OSCategory)) { Add-Metric "Failed by OS" $g.Name $g.Count }
foreach ($g in ($biz | Where-Object { $_.ComplianceStatus -eq "Non-Compliant" } | Group-Object Region))     { Add-Metric "Failed by Region" $g.Name $g.Count }
foreach ($g in ($biz | Where-Object { $_.ComplianceStatus -eq "Non-Compliant" } | Group-Object Tier))       { Add-Metric "Failed by Tier" $g.Name $g.Count }
foreach ($g in $biz | Group-Object MgmtTechnique) { Add-Metric "Mgmt Technique" $g.Name $g.Count }
Add-Metric "Pending First Management" "All" (@($biz | Where-Object { $_.ComplianceStatus -eq "Pending/Unknown" }).Count)
foreach ($g in $biz | Group-Object VerifyStatus) { Add-Metric "Verification Status" $g.Name $g.Count }
Add-Metric "Rotation Overdue" "All" (@($biz | Where-Object { $_.RotationOverdue }).Count)
foreach ($g in ($biz | Where-Object { $_.RotationOverdue } | Group-Object Region)) { Add-Metric "Rotation Overdue by Region" $g.Name $g.Count }
foreach ($g in ($biz | Where-Object { $_.RotationOverdue } | Group-Object Tier))   { Add-Metric "Rotation Overdue by Tier" $g.Name $g.Count }
foreach ($g in ($biz | Where-Object { $_.RotationOverdue } | Group-Object OSCategory)) { Add-Metric "Rotation Overdue by OS" $g.Name $g.Count }
Add-Metric "Stale Accounts (>= $StaleAccountDays d)" "All" (@($biz | Where-Object { $_.IsStale }).Count)
Add-Metric "Never Verified (Auto-Managed)" "All" (@($biz | Where-Object { $_.VerifyStatus -eq 'Never Verified' }).Count)

# Users
Add-Metric "Total Users" "All" $UsersRaw.Count
Add-Metric "Real Users" "All" $realUsers.Count
Add-Metric "Active Users (<= $LoginWindowDays d)" "All" (@($realUsers | Where-Object { $_.LoginStatus -like 'Active*' }).Count)
Add-Metric "Dormant Users" "All" (@($realUsers | Where-Object { $_.LoginStatus -like 'Dormant*' }).Count)
Add-Metric "Never Logged In Users" "All" (@($realUsers | Where-Object { $_.LoginStatus -eq 'Never Logged In' }).Count)



# Onboarding trend
Write-Log "Building onboarding trend (last $TrendLookbackMonths months)..." INFO
$trendCutoff = [datetime]::new((Get-Date).AddMonths(-1 * $TrendLookbackMonths).Year, (Get-Date).AddMonths(-1 * $TrendLookbackMonths).Month, 1)

$acctTrend = $biz | Where-Object { $_.CreatedMonth -and ([datetime]::ParseExact("$($_.CreatedMonth)-01","yyyy-MM-dd",$null) -ge $trendCutoff) } |
    Group-Object CreatedMonth | Sort-Object Name
foreach ($g in $acctTrend) { Add-Metric "Accounts Onboarded by Month" $g.Name $g.Count }

$safeTrend = $bizSafes | Where-Object { $_.CreatedDate -and ([datetime]$_.CreatedDate -ge $trendCutoff) } |
    ForEach-Object { [pscustomobject]@{ Month = ([datetime]$_.CreatedDate).ToString("yyyy-MM") } } |
    Group-Object Month | Sort-Object Name
foreach ($g in $safeTrend) { Add-Metric "Safes Onboarded by Month" $g.Name $g.Count }

Add-Metric "Accounts Recently Onboarded (<= $OnboardingWindowDays d)" "All" (@($biz | Where-Object { $_.RecentlyOnboarded }).Count)
Add-Metric "Safes Recently Created (<= $OnboardingWindowDays d)" "All" (@($bizSafes | Where-Object { $_.RecentlyCreated }).Count)

Write-Log "Metrics rows: $($MetricsRows.Count)" SUCCESS
$RecordCounts["FACT_MetricsSummary"] = $MetricsRows.Count

# ══════════════════════════════════════════════════════════════════════════════
#  STEP 16 : ONBOARDING TREND TABLE → FACT_OnboardingTrend.csv
# ══════════════════════════════════════════════════════════════════════════════
Write-Log "=== Step 16: Building Onboarding Trend Table ===" SECTION
$TrendRows = [System.Collections.Generic.List[PSCustomObject]]::new()

# Generate all months in range even if 0
$mStart = $trendCutoff
while ($mStart -le (Get-Date)) {
    $mKey = $mStart.ToString("yyyy-MM")
    $acctCount = 0; $safeCount = 0
    $ag = $acctTrend | Where-Object { $_.Name -eq $mKey }
    if ($ag) { $acctCount = $ag.Count }
    $sg = $safeTrend | Where-Object { $_.Name -eq $mKey }
    if ($sg) { $safeCount = $sg.Count }
    $TrendRows.Add([pscustomobject]@{
        Month           = $mKey
        Year            = $mStart.Year
        MonthNumber     = $mStart.Month
        MonthName       = $mStart.ToString("MMM")
        AccountsOnboarded = $acctCount
        SafesCreated    = $safeCount
        ExtractDate     = $ExtractDate
    })
    $mStart = $mStart.AddMonths(1)
}
$RecordCounts["FACT_OnboardingTrend"] = $TrendRows.Count

# ══════════════════════════════════════════════════════════════════════════════
#  STEP 17 : GENERATE DIMENSION TABLES → DIM_Date.csv + DIM_Region.csv
# ══════════════════════════════════════════════════════════════════════════════
Write-Log "=== Step 17: Generating Dimension Tables ===" SECTION

# DIM_Date: calendar table spanning 3 years back to 1 year ahead
$dimDateStart = (Get-Date).AddYears(-3).Date
$dimDateEnd   = (Get-Date).AddYears(1).Date
$DimDate = [System.Collections.Generic.List[PSCustomObject]]::new()
$dt = $dimDateStart
while ($dt -le $dimDateEnd) {
    $DimDate.Add([pscustomobject]@{
        DateKey     = $dt.ToString("yyyy-MM-dd")
        Year        = $dt.Year
        Quarter     = "Q" + [math]::Ceiling($dt.Month / 3)
        MonthNumber = $dt.Month
        MonthName   = $dt.ToString("MMM")
        MonthKey    = $dt.ToString("yyyy-MM")
        WeekOfYear  = [int]([System.Globalization.CultureInfo]::InvariantCulture.Calendar.GetWeekOfYear($dt, [System.Globalization.CalendarWeekRule]::FirstFourDayWeek, [DayOfWeek]::Monday))
        DayOfWeek   = [int]$dt.DayOfWeek
        DayName     = $dt.ToString("ddd")
        IsWeekend   = ($dt.DayOfWeek -eq [DayOfWeek]::Saturday -or $dt.DayOfWeek -eq [DayOfWeek]::Sunday)
    })
    $dt = $dt.AddDays(1)
}
$RecordCounts["DIM_Date"] = $DimDate.Count

# DIM_Region: derived from config
$DimRegion = [System.Collections.Generic.List[PSCustomObject]]::new()
$seenRegions = @{}
foreach ($k in $RegionPrefixes.Keys) {
    $rn = $RegionPrefixes[$k]
    if (-not $seenRegions.ContainsKey($rn)) {
        $seenRegions[$rn] = $true
        $prefixes = @($RegionPrefixes.Keys | Where-Object { $RegionPrefixes[$_] -eq $rn }) -join ", "
        $DimRegion.Add([pscustomobject]@{ RegionKey=$rn; RegionName=$rn; Prefixes=$prefixes })
    }
}
$DimRegion.Add([pscustomobject]@{ RegionKey="Non-standard"; RegionName="Non-standard"; Prefixes="" })
$DimRegion.Add([pscustomobject]@{ RegionKey="N/A-Default"; RegionName="N/A-Default"; Prefixes="" })
$RecordCounts["DIM_Region"] = $DimRegion.Count

# ══════════════════════════════════════════════════════════════════════════════
#  STEP 18 : EXPORT ALL CSVs TO Latest/
# ══════════════════════════════════════════════════════════════════════════════
Write-Log "=== Step 18: Exporting CSV Files ===" SECTION

# Each entry carries an explicit column schema (Cols). When a table has rows we let
# Export-Csv infer the header from the objects (same order as Cols); when a table is
# EMPTY we still write these column headers so Power BI keeps a stable schema and the
# pre-built relationships/visuals don't break on refresh.
$CsvExports = @(
    @{ Name="DIM_Date";              Data=$DimDate;              File="$LatestDir\DIM_Date.csv";
       Cols=@("DateKey","Year","Quarter","MonthNumber","MonthName","MonthKey","WeekOfYear","DayOfWeek","DayName","IsWeekend") },
    @{ Name="DIM_Region";            Data=$DimRegion;            File="$LatestDir\DIM_Region.csv";
       Cols=@("RegionKey","RegionName","Prefixes") },
    @{ Name="DIM_Platform";          Data=$DimPlatform;          File="$LatestDir\DIM_Platform.csv";
       Cols=@("PlatformID","PlatformName","SystemType","Active","PlatformBaseID","PlatformType","OSCategory","RotationDays","ExtractDate") },
    @{ Name="DIM_Safe";              Data=$DimSafe;              File="$LatestDir\DIM_Safe.csv";
       Cols=@("SafeName","SafeUrlId","SafeNumber","Description","Location","Creator","ManagingCPM","NumberOfAccounts","OLACEnabled","AutoPurge","RetentionVersions","RetentionDays","CreatedDate","CreatedDateTime","LastModifiedDateTime","IsDefault","SafeType","Region","Tier","HasCPM","IsEmpty","RecentlyCreated","NamingCompliant","ExtractDate") },
    @{ Name="FACT_Accounts";         Data=$FactAccounts;         File="$LatestDir\FACT_Accounts.csv";
       Cols=@("AccountID","Name","UserName","Address","SafeName","PlatformID","SecretType","IsDefaultSafe","SafeType","Region","Tier","OSCategory","AutoManaged","MgmtTechnique","ManualReason","ComplianceStatus","SecretStatus","LastChangeDate","LastChangeDateTime","DaysSinceChange","ExpectedRotationDays","RotationOverdue","LastVerifyDate","DaysSinceVerify","VerifyStatus","LastReconciledDate","IsStale","CreatedDate","CreatedMonth","AccountAgeDays","RecentlyOnboarded","NameCompliant","AddressCompliant","HasAddress","ExtractDate") },
    @{ Name="FACT_Users";            Data=$FactUsers;            File="$LatestDir\FACT_Users.csv";
       Cols=@("UserName","UserID","Source","UserType","ComponentUser","IsComponent","Enabled","Suspended","Location","FirstName","LastName","Email","VaultAuth","PasswordNeverExpires","LastLoginDate","LastLoginDateTime","DaysSinceLogin","LoginStatus","ExtractDate") },
    @{ Name="FACT_Groups";           Data=$FactGroups;           File="$LatestDir\FACT_Groups.csv";
       Cols=@("GroupName","GroupID","GroupType","Directory","Location","IsDefault","ExtractDate") },
    @{ Name="FACT_CPMFailed";        Data=$CPMFailedRows;        File="$LatestDir\FACT_CPMFailed.csv";
       Cols=@("AccountID","AccountName","Address","PlatformID","SafeName","Region","Tier","CPMStatus","ManualReason","LastModified","LastVerified","LastReconciled","CreatedDate","ExtractDate") },
    @{ Name="FACT_PlatformSummary";  Data=$FactPlatformSummary;  File="$LatestDir\FACT_PlatformSummary.csv";
       Cols=@("PlatformID","TotalAccounts","ManagedCount","UnmanagedCount","SuccessCount","FailedCount","ManagedPct","SuccessRatePct","IsUsed","ExtractDate") },
    @{ Name="FACT_VaultConnectivity";Data=$VaultRows;            File="$LatestDir\FACT_VaultConnectivity.csv";
       Cols=@("ComponentType","InstanceIP","VaultUserName","ComponentVersion","IsLoggedOn","LastLogonDate","ExtractDate") },
    @{ Name="FACT_SafeMembers";      Data=$MemberRows;           File="$LatestDir\FACT_SafeMembers.csv";
       Cols=@("SafeName","IsDefaultSafe","Region","Tier","MemberName","MemberID","MemberType","IsDefaultMember","IsSafeManager","MemberCategory","IsPredefinedUser","IsReadOnly","MembershipExpirationDate","Permissions","ExtractDate") },
    @{ Name="FACT_AdminAudit";       Data=$AdminAuditRows;       File="$LatestDir\FACT_AdminAudit.csv";
       Cols=@("SafeName","IsDefaultSafe","Region","Tier","GroupName","GroupExists","PermissionLevel","MissingPermissions","ExtractDate") },
    @{ Name="FACT_OnboardingTrend";  Data=$TrendRows;            File="$LatestDir\FACT_OnboardingTrend.csv";
       Cols=@("Month","Year","MonthNumber","MonthName","AccountsOnboarded","SafesCreated","ExtractDate") },
    @{ Name="FACT_MetricsSummary";   Data=$MetricsRows;          File="$LatestDir\FACT_MetricsSummary.csv";
       Cols=@("Metric","Dimension","Value") }
)

foreach ($export in $CsvExports) {
    try {
        if ($export.Data.Count -gt 0) {
            $export.Data | Export-Csv -Path $export.File -NoTypeInformation -Encoding UTF8 -Force
            Write-Log "  [OK] $($export.Name) ($($export.Data.Count) rows)" SUCCESS
        } else {
            # Header-only CSV: write the real column headers (quoted, matching Export-Csv output)
            # so Power BI keeps a stable schema even when a table has no rows this run.
            $headerLine = ($export.Cols | ForEach-Object { '"' + $_ + '"' }) -join ','
            Set-Content -Path $export.File -Value $headerLine -Encoding UTF8 -Force
            Write-Log "  [--] $($export.Name) (0 rows - header-only placeholder)" INFO
        }
    } catch {
        Write-Log "  [FAIL] $($export.Name): $($_.Exception.Message)" ERROR
        $RunErrors.Add("CSV Export ($($export.Name)): $($_.Exception.Message)")
    }
}

# ══════════════════════════════════════════════════════════════════════════════
#  STEP 19 : ARCHIVE + RUN METADATA
# ══════════════════════════════════════════════════════════════════════════════
Write-Log "=== Step 19: Archive & Metadata ===" SECTION

# Archive
try {
    Get-ChildItem -Path $LatestDir -File | ForEach-Object { Copy-Item -Path $_.FullName -Destination $ArchiveDir -Force }
    Write-Log "All files archived to: $ArchiveDir" SUCCESS
} catch {
    Write-Log "Failed to archive: $($_.Exception.Message)" ERROR
    $RunErrors.Add("Archive: $($_.Exception.Message)")
}

# Run metadata JSON
$ScriptEndTime   = Get-Date
$DurationSeconds = [math]::Round(($ScriptEndTime - $ScriptStartTime).TotalSeconds, 1)

$RunInfo = [ordered]@{
    RunTimestamp     = (Get-Date -Format "yyyy-MM-ddTHH:mm:ssK")
    DurationSeconds  = $DurationSeconds
    Status           = if ($RunErrors.Count -eq 0) { "Success" } else { "CompletedWithErrors" }
    ExtractDate      = $ExtractDate
    PowerShellVersion = "$($PSVersionTable.PSVersion)"
    OptInFlags       = [ordered]@{
        CollectSafeMembers        = $CollectSafeMembers
    }
    RecordCounts     = $RecordCounts
    Errors           = $RunErrors
}

$RunInfoJson = $RunInfo | ConvertTo-Json -Depth 4
$RunInfoJson | Out-File -FilePath "$LatestDir\_RunMetadata.json" -Encoding UTF8 -Force
Write-Log "Run metadata written: $LatestDir\_RunMetadata.json" SUCCESS

# ══════════════════════════════════════════════════════════════════════════════
#  STEP 20 : CONSOLE SUMMARY REPORT
# ══════════════════════════════════════════════════════════════════════════════
$Divider    = "=" * 75
$SubDivider = "-" * 75

Write-Host ""
Write-Host $Divider -ForegroundColor White
Write-Host "  CYBERARK PRIVILEGE CLOUD — UNIFIED DASHBOARD EXPORT (V3)" -ForegroundColor White
Write-Host "  Generated : $(Get-Date -Format 'yyyy-MM-dd HH:mm:ss')" -ForegroundColor White
Write-Host "  Duration  : $DurationSeconds seconds" -ForegroundColor White
Write-Host $Divider -ForegroundColor White

# ── Inventory
Write-Host ""
Write-Host "  INVENTORY" -ForegroundColor Cyan
Write-Host $SubDivider -ForegroundColor DarkGray
Write-Host ("  Safes               : {0} total | {1} business | {2} default" -f $DimSafe.Count, $bizSafes.Count, ($DimSafe.Count - $bizSafes.Count)) -ForegroundColor White
Write-Host ("  Accounts            : {0} total | {1} business" -f $AcctRaw.Count, $biz.Count) -ForegroundColor White
Write-Host ("  Users               : {0} total | {1} real | {2} active" -f $UsersRaw.Count, $realUsers.Count, @($realUsers | Where-Object { $_.LoginStatus -like 'Active*' }).Count) -ForegroundColor White
Write-Host ("  Groups              : {0}" -f $GroupsRaw.Count) -ForegroundColor White
Write-Host ("  Platforms           : {0} total | {1} active" -f $PlatRaw.Count, @($DimPlatform | Where-Object { $_.Active }).Count) -ForegroundColor White

# ── Compliance
Write-Host ""
Write-Host "  COMPLIANCE" -ForegroundColor Cyan
Write-Host $SubDivider -ForegroundColor DarkGray
$compliant    = @($biz | Where-Object { $_.ComplianceStatus -eq "Compliant" }).Count
$nonCompliant = @($biz | Where-Object { $_.ComplianceStatus -eq "Non-Compliant" }).Count
$pending      = @($biz | Where-Object { $_.ComplianceStatus -eq "Pending/Unknown" }).Count
$compRate     = if ($biz.Count -gt 0) { [math]::Round(($compliant / $biz.Count) * 100, 1) } else { 0 }
Write-Host ("  Compliance Rate     : {0}%  ({1} compliant / {2} non-compliant / {3} pending)" -f $compRate, $compliant, $nonCompliant, $pending) `
    -ForegroundColor $(if ($compRate -ge 90) { "Green" } elseif ($compRate -ge 70) { "Yellow" } else { "Red" })
Write-Host ("  Rotation Overdue    : {0}" -f @($biz | Where-Object { $_.RotationOverdue }).Count) `
    -ForegroundColor $(if (@($biz | Where-Object { $_.RotationOverdue }).Count -gt 0) { "Yellow" } else { "Green" })
Write-Host ("  Stale (>= {0}d)      : {1}" -f $StaleAccountDays, @($biz | Where-Object { $_.IsStale }).Count) -ForegroundColor White
Write-Host ("  Non-standard Names  : {0} safes" -f @($bizSafes | Where-Object { -not $_.NamingCompliant }).Count) `
    -ForegroundColor $(if (@($bizSafes | Where-Object { -not $_.NamingCompliant }).Count -gt 0) { "Yellow" } else { "Green" })

# ── Infrastructure (Vault Connectivity)
Write-Host ""
Write-Host "  INFRASTRUCTURE (VAULT CONNECTIVITY)" -ForegroundColor Cyan
Write-Host $SubDivider -ForegroundColor DarkGray
foreach ($compType in $VaultComponentIDs) {
    $typeRows  = @($VaultRows | Where-Object { $_.ComponentType -eq $compType })
    $loggedOn  = @($typeRows | Where-Object { $_.IsLoggedOn -eq "TRUE" }).Count
    if ($typeRows.Count -gt 0) {
        $label = switch ($compType) { "CPM" { "CPM" } "SessionManagement" { "PSM" } "AIM" { "AIM" } default { $compType } }
        Write-Host ("  {0,-20} : {1} total | {2} connected" -f $label, $typeRows.Count, $loggedOn) `
            -ForegroundColor $(if ($loggedOn -lt $typeRows.Count) { "Red" } else { "Green" })
    }
}

# ── CPM
Write-Host ""
Write-Host "  CPM OPERATIONS" -ForegroundColor Cyan
Write-Host $SubDivider -ForegroundColor DarkGray
Write-Host ("  CPM Failed/Pending  : {0}" -f $CPMFailedRows.Count) `
    -ForegroundColor $(if ($CPMFailedRows.Count -gt 0) { "Red" } else { "Green" })
Write-Host ("  Platforms Tracked   : {0}" -f $FactPlatformSummary.Count) -ForegroundColor White

# ── Opt-in stages
if ($CollectSafeMembers) {
    Write-Host ""
    Write-Host "  SAFE MEMBERS & ADMIN AUDIT" -ForegroundColor Cyan
    Write-Host $SubDivider -ForegroundColor DarkGray
    Write-Host ("  Safe Members        : {0}" -f $MemberRows.Count) -ForegroundColor White
    Write-Host ("  Admin Audit Rows    : {0}" -f $AdminAuditRows.Count) -ForegroundColor White
}

# ── Output
Write-Host ""
Write-Host "  OUTPUT" -ForegroundColor Cyan
Write-Host $SubDivider -ForegroundColor DarkGray
Write-Host ("  Metrics Rows        : {0}" -f $MetricsRows.Count) -ForegroundColor Green
Write-Host ("  CSV Files           : {0}" -f $CsvExports.Count) -ForegroundColor Green
Write-Host ("  Latest (Power BI)   : {0}" -f $LatestDir) -ForegroundColor Green
Write-Host ("  Archive (This Run)  : {0}" -f $ArchiveDir) -ForegroundColor Green
Write-Host ("  Run Metadata        : {0}" -f "$LatestDir\_RunMetadata.json") -ForegroundColor White
Write-Host ("  Duration            : {0}s" -f $DurationSeconds) -ForegroundColor White
Write-Host ("  Errors              : {0}" -f $RunErrors.Count) -ForegroundColor $(if ($RunErrors.Count -gt 0) { "Red" } else { "Green" })

if ($RunErrors.Count -gt 0) {
    Write-Host ""
    Write-Host "  Error Details:" -ForegroundColor Red
    foreach ($err in $RunErrors) { Write-Host "    * $err" -ForegroundColor Red }
}

Write-Host ""
Write-Host $Divider -ForegroundColor White
Write-Log "=== CyberArk Unified Dashboard Export V3 Complete ===" SECTION
