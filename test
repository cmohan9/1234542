    }
})
$SafeFact | Export-Csv "$OutputDir\Safes_Info.csv" -NoTypeInformation -Encoding UTF8
$SafeLookup=@{}; foreach($f in $SafeFact){ $SafeLookup[$f.SafeName]=$f }
Write-Log "Safes: total=$($SafesRaw.Count) default=$(@($SafeFact|?{$_.IsDefault}).Count)" SUCCESS

