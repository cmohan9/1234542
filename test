# filename: cyberark-ops-metrics.ps1
# Code Generated by Sidekick is for learning and experimentation purposes only.
# CyberArk Privilege Cloud (SaaS) operational metrics exporter. Runs on Windows
# PowerShell 5.1+ (no PS7 required). Emits per-entity <Entity>_Raw.csv (readable,
# real dates) + <Entity>_Info.csv (criteria-based) plus a long-format
# Metrics_Summary.csv. Optional stages (opt-in): Safe Members, and per-account
# activity for an "onboarded vs used" view (throttled runspace pool + cache).

# ══════════════════════════════════════════════════════════════════════════════
#  SECTION A : CREDENTIALS
# ══════════════════════════════════════════════════════════════════════════════
$IdentityTenantId  = "XXXXXXXXXXX"
$ServiceUserId     = "apiuser@XXXXXXXXXXXXX"
$ServiceUserSecret = "XXXXXXXXXXXXXX"
$Subdomain         = "XXXXXXXXXXX"

$IdentityUrl = "https://$IdentityTenantId.id.cyberark.cloud"
$PvwaBase    = "https://$Subdomain.privilegecloud.cyberark.cloud/PasswordVault/API"

# ══════════════════════════════════════════════════════════════════════════════
#  SECTION B : EDITABLE THRESHOLDS
# ══════════════════════════════════════════════════════════════════════════════
$LoginWindowDays     = 30    # users considered "active" if logged in within N days
$OnboardingWindowDays= 30    # accounts/safes "recently onboarded"
$StaleAccountDays     = 90    # no password change in N days = stale (proxy, NOT usage)
$VerifyOverdueDays    = 7     # verification must occur every 7 days
$TrendLookbackMonths  = 12    # onboarding trend history
$TopNSafes            = 10    # heaviest safes by account count

# ══════════════════════════════════════════════════════════════════════════════
#  SECTION C : RUNTIME
# ══════════════════════════════════════════════════════════════════════════════
$PageLimit         = 1000
$MaxRetries        = 4
$RetryWaitSeconds  = 5
$CollectSafeMembers= $false   # set $true to enable membership/orphan metrics (1 call per safe)

# ── Account activity ("onboarded vs used") - opt-in, ~1 call per business account
$CollectAccountActivity = $false  # set $true to compute per-account "last used"
$ActivityThrottleLimit  = 10      # concurrent runspaces for the activity fan-out (PS 5.1+)
$ActivityBatchSize      = 300     # accounts per batch; token is refreshed before each batch
$ActivityCacheTTLHours  = 20      # reuse a cached account result younger than this (0 = always refetch)
$ActivityForceRefresh   = $false  # $true = ignore the cache and refetch every account

# Safe Members is the one stage with a real 1-call-per-safe fan-out; it runs
# sequentially so this script works on Windows PowerShell 5.1 (no PS7+ needed).
# Every other stage (Safes/Users/Groups/Platforms/Accounts) is already a small,
# fixed number of bulk/paged calls, so there's nothing else to fan out.
# Ensure TLS 1.2 is enabled (required on Windows PowerShell 5.1, harmless on 7+).
try {
    [Net.ServicePointManager]::SecurityProtocol = [Net.ServicePointManager]::SecurityProtocol -bor [Net.SecurityProtocolType]::Tls12
} catch { }

