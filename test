$LatestFolder = Join-Path $RootFolder "Latest"
$ArchiveRoot  = Join-Path $RootFolder "Archive"

# ─── PS VERSION COMPAT ────────────────────────────────────────────────────────────────────────
$PSMajorVersion = $PSVersionTable.PSVersion.Major
$IsPS7Plus      = $PSMajorVersion -ge 7

if (-not $IsPS7Plus) {
    # PS7+ negotiates modern TLS automatically; Windows PowerShell 5.1 often needs this nudge.
    try {
        [Net.ServicePointManager]::SecurityProtocol = [Net.ServicePointManager]::SecurityProtocol -bor [Net.SecurityProtocolType]::Tls12
    } catch {
        Write-Warning "Could not force TLS 1.2 on this PowerShell 5.1 host: $($_.Exception.Message)"
    }
}

# ─── ARCHIVE ROTATION (runs before logging starts, so it can't write to the log yet) ──────────
function Invoke-ArchiveRotation {
    param([string]$LatestFolder, [string]$ArchiveRoot)

    if (-not (Test-Path $RootFolder)) {
        New-Item -ItemType Directory -Path $RootFolder -Force | Out-Null
    }

    if (-not (Test-Path $LatestFolder)) {
        New-Item -ItemType Directory -Path $LatestFolder -Force | Out-Null
        return $null
    }

    $existingItems = Get-ChildItem -Path $LatestFolder -Force -ErrorAction SilentlyContinue
    if (-not $existingItems -or @($existingItems).Count -eq 0) {
        return $null
    }

    $manifestPath = Join-Path $LatestFolder "manifest.json"
    $archiveStamp = $null
    if (Test-Path $manifestPath) {
        try {
            $oldManifest = Get-Content -Path $manifestPath -Raw | ConvertFrom-Json
            if ($oldManifest.RunTimestamp) {
                $archiveStamp = ([datetime]$oldManifest.RunTimestamp).ToString("yyyyMMdd_HHmmss")
            }
        } catch { }
    }
    if (-not $archiveStamp) {
        $oldest       = $existingItems | Sort-Object LastWriteTime | Select-Object -First 1
        $archiveStamp = $oldest.LastWriteTime.ToString("yyyyMMdd_HHmmss")
    }

    if (-not (Test-Path $ArchiveRoot)) {
        New-Item -ItemType Directory -Path $ArchiveRoot -Force | Out-Null
    }

    $archiveDest = Join-Path $ArchiveRoot $archiveStamp
    $suffix = 1
    while (Test-Path $archiveDest) {
        $archiveDest = Join-Path $ArchiveRoot "$archiveStamp`_$suffix"
        $suffix++
    }
    New-Item -ItemType Directory -Path $archiveDest -Force | Out-Null

    foreach ($item in $existingItems) {
        Move-Item -Path $item.FullName -Destination $archiveDest -Force
    }

    New-Item -ItemType Directory -Path $LatestFolder -Force | Out-Null
    return $archiveDest
}

$ArchivedTo = Invoke-ArchiveRotation -LatestFolder $LatestFolder -ArchiveRoot $ArchiveRoot

# ─── LOGGING ──────────────────────────────────────────────────────────────────────────────────
$LogFile        = Join-Path $LatestFolder "run.log"
$script:WarnCount  = 0
$script:ErrorCount = 0

function Write-Log {
    param(
        [string]$Message,
        [ValidateSet("INFO", "WARN", "ERROR", "SUCCESS", "DEBUG", "SECTION")]
        [string]$Level = "INFO"
    )
    $ts   = Get-Date -Format "yyyy-MM-dd HH:mm:ss"
    $line = "[$ts] [$Level] $Message"
    Add-Content -Path $LogFile -Value $line

    if ($Level -eq "WARN")  { $script:WarnCount++ }
    if ($Level -eq "ERROR") { $script:ErrorCount++ }

    switch ($Level) {
        "INFO"    { Write-Host $line -ForegroundColor Cyan }
        "WARN"    { Write-Host $line -ForegroundColor Yellow }
        "ERROR"   { Write-Host $line -ForegroundColor Red }
        "SUCCESS" { Write-Host $line -ForegroundColor Green }
        "DEBUG"   { Write-Host $line -ForegroundColor DarkGray }
        "SECTION" { Write-Host "`n$line`n" -ForegroundColor Magenta }
    }
}

Write-Log "=== CyberArk Dashboard Data Export Started ===" -Level SECTION
Write-Log "PowerShell version: $($PSVersionTable.PSVersion) (PS7+ mode: $IsPS7Plus)" -Level INFO
Write-Log "Latest folder     : $LatestFolder" -Level INFO
if ($ArchivedTo) {
    Write-Log "Previous run archived to: $ArchivedTo" -Level INFO
} else {
    Write-Log "No previous run found to archive." -Level INFO
}

$RunStartUtc = (Get-Date).ToUniversalTime()

# ─── TOKEN MANAGEMENT ─────────────────────────────────────────────────────────────────────────
$script:AccessToken    = $null
$script:TokenExpiryUtc = [datetime]::MinValue

function Get-CyberArkToken {
    $body = @{
        grant_type    = "client_credentials"
        client_id     = $ServiceUserId
        client_secret = $ServiceUserSecret
    }
    $resp = Invoke-RestMethod -Uri "$IdentityUrl/oauth2/platformtoken" -Method POST -Body $body `
        -ContentType "application/x-www-form-urlencoded" -ErrorAction Stop

    $script:AccessToken = $resp.access_token
    $expiresIn = 900
    if ($resp.expires_in) { $expiresIn = [int]$resp.expires_in }
    # Refresh 60s before actual expiry to avoid a request landing right on the boundary.
    $bufferSeconds = 60
    if ($expiresIn -le $bufferSeconds) { $bufferSeconds = [Math]::Floor($expiresIn / 2) }
    $script:TokenExpiryUtc = (Get-Date).ToUniversalTime().AddSeconds($expiresIn - $bufferSeconds)
    Write-Log "Authenticated. Token valid for ~$expiresIn sec (refresh scheduled before expiry)." -Level SUCCESS
}

function Get-AuthHeaders {
    if (-not $script:AccessToken -or (Get-Date).ToUniversalTime() -ge $script:TokenExpiryUtc) {
        Write-Log "Access token missing or nearing expiry - refreshing..." -Level INFO
        Get-CyberArkToken
    }
    return @{
        Authorization  = "Bearer $script:AccessToken"
        "Content-Type" = "application/json"
    }
}

try {
    Get-CyberArkToken
} catch {
    Write-Log "Initial authentication FAILED: $($_.Exception.Message)" -Level ERROR
    Write-Log "Cannot continue. Exiting." -Level ERROR
    exit 1
}

# ─── GENERIC READ-ONLY GET WRAPPER (retry + auto token refresh on 401) ────────────────────────
function Invoke-ApiGet {
    param([Parameter(Mandatory)][string]$Uri)

    $attempt       = 0
    $forcedRefresh = $false

    while ($attempt -le $MaxRetries) {
        $attempt++
        $headers = Get-AuthHeaders
        try {
            Write-Log "GET $Uri (attempt $attempt)" -Level DEBUG
            return Invoke-RestMethod -Uri $Uri -Method GET -Headers $headers -ErrorAction Stop
        } catch {
            $statusCode = $null
            if ($_.Exception.Response) {
                try { $statusCode = [int]$_.Exception.Response.StatusCode } catch { }
            }
            $msg = $_.Exception.Message

            if ($statusCode -eq 401 -and -not $forcedRefresh) {
                Write-Log "GET $Uri - HTTP 401 - forcing token refresh and retrying once" -Level WARN
                $forcedRefresh      = $true
                $script:AccessToken = $null
                continue
            }

            if ($statusCode -in @(400, 403, 404)) {
                Write-Log "GET $Uri - HTTP $statusCode - $msg (no retry)" -Level ERROR
                return $null
            }

            if ($attempt -le $MaxRetries) {
                $wait = $RetryWaitSeconds * $attempt
                Write-Log "GET $Uri - HTTP $statusCode - $msg (retrying in ${wait}s...)" -Level WARN
                Start-Sleep -Seconds $wait
            } else {
                Write-Log "GET $Uri - HTTP $statusCode - $msg (all retries exhausted)" -Level ERROR
                return $null
            }
        }
    }
    return $null
}

# ─── GENERIC PAGINATION (value/nextLink style, with graceful fallback for unknown shapes) ─────
function Get-PagedCollection {
    param(
        [Parameter(Mandatory)][string]$BaseUri,
        [int]$PageSize = 100,
        [switch]$NoOffsetParams
    )

    $results = [System.Collections.Generic.List[object]]::new()
    $uri  = $BaseUri
    if (-not $NoOffsetParams) {
        $separator = if ($BaseUri -match '\?') { '&' } else { '?' }
        $uri = "$BaseUri${separator}offset=0&limit=$PageSize"
    }
    $page = 1

    while ($uri) {
        Write-Log "Fetching page $page : $uri" -Level DEBUG
        $resp = Invoke-ApiGet -Uri $uri
        if ($null -eq $resp) {
            Write-Log "Null/failed response on page $page for $BaseUri - stopping pagination." -Level WARN
            break
        }

        $batch = $null
        if ($resp.PSObject.Properties.Name -contains 'value') {
            $batch = $resp.value
        } elseif ($resp -is [System.Array]) {
            $batch = $resp
        } else {
            $arrayProp = $resp.PSObject.Properties | Where-Object { $_.Value -is [System.Array] } | Select-Object -First 1
            if ($arrayProp) { $batch = $arrayProp.Value }
        }

        if ($null -eq $batch) {
            $keys = ($resp.PSObject.Properties.Name -join ', ')
            Write-Log "Unrecognized response shape on page $page for $BaseUri - keys seen: $keys" -Level WARN
            break
        }

        foreach ($item in @($batch)) { $results.Add($item) }
        Write-Log "Page $page - received $(@($batch).Count) record(s) (running total: $($results.Count))" -Level INFO

        $nextLink = $resp.nextLink
        if ($nextLink) {
            if ($nextLink -notmatch '^https?://') {
                $rootUri    = [Uri]$PvwaBase
                $serverRoot = "$($rootUri.Scheme)://$($rootUri.Host)"
                if ($nextLink.StartsWith('/')) {
                    $nextLink = "$serverRoot$nextLink"
                } else {
                    $nextLink = "$PvwaBase/$nextLink"
                }
            }
            $uri = $nextLink
            $page++
        } else {
            $uri = $null
        }
    }

    return $results
}

# ─── HELPERS ──────────────────────────────────────────────────────────────────────────────────
# Only for use when $SafeName is the LAST segment of the URL path (e.g. a
# single-safe lookup). CyberArk's API misreads a trailing dot in the final
# path segment as a format suffix, so that case needs a trailing slash.
# Do NOT use this for a safe name that's a middle segment (e.g. .../Safes/
# {name}/Members) - appending the slash there produces a double slash
# ("...//Members") since another path segment already follows.
function Get-SafeUrlSegment {
    param([string]$SafeName)
    $encoded = [Uri]::EscapeDataString($SafeName)
    if ($SafeName -match '\.') { return "$encoded/" }
    return $encoded
}

function Get-FirstPropertyValue {
    param($Object, [string[]]$CandidateNames)
    if ($null -eq $Object) { return $null }
    foreach ($name in $CandidateNames) {
        if ($Object.PSObject.Properties.Name -contains $name) {
            $val = $Object.$name
            if ($null -ne $val -and $val -ne '') { return $val }
        }
    }
    return $null
}

# Flattens arbitrarily-nested JSON objects into dotted-key flat objects, so CSV
# export doesn't break (or silently drop data) when the real CyberArk response
# schema differs from what's expected here.
function ConvertTo-FlatObject {
    param($InputObject, [string]$Prefix = "")

    $result = [ordered]@{}
    if ($null -eq $InputObject) { return [PSCustomObject]$result }

    foreach ($p in $InputObject.PSObject.Properties) {
        $key = if ($Prefix) { "$Prefix.$($p.Name)" } else { $p.Name }
        $val = $p.Value

        if ($null -eq $val) {
            $result[$key] = ""
        } elseif ($val -is [System.Management.Automation.PSCustomObject] -or $val -is [Hashtable]) {
            $nested = ConvertTo-FlatObject -InputObject $val -Prefix $key
            foreach ($np in $nested.PSObject.Properties) { $result[$np.Name] = $np.Value }
        } elseif (($val -is [System.Collections.IEnumerable]) -and -not ($val -is [string])) {
            $items = @($val)
            if ($items.Count -eq 0) {
                $result[$key] = ""
            } elseif ($items[0] -is [System.Management.Automation.PSCustomObject] -or $items[0] -is [Hashtable]) {
                $result[$key] = ($items | ForEach-Object { $_ | ConvertTo-Json -Compress -Depth 6 }) -join " | "
            } else {
                $result[$key] = ($items -join "; ")
            }
        } else {
            $result[$key] = $val
        }
    }
    return [PSCustomObject]$result
}

# Flattens + normalizes a list of objects to a common column set (union of all
# keys seen) before Export-Csv, so ragged/variable schemas don't produce
# missing columns or errors.
function Export-FlattenedCsv {
    param([Parameter(Mandatory)]$Objects, [Parameter(Mandatory)][string]$Path)

    if (-not $Objects -or @($Objects).Count -eq 0) {
        Write-Log "No rows to export for $Path - writing header-only placeholder." -Level WARN
        [PSCustomObject]@{ Note = "No data returned by API for this run" } | Export-Csv -Path $Path -NoTypeInformation -Encoding UTF8
        return
    }

    $flatObjects = @($Objects | ForEach-Object { ConvertTo-FlatObject -InputObject $_ })

    $allKeys = [System.Collections.Generic.List[string]]::new()
    $seen    = @{}
    foreach ($obj in $flatObjects) {
        foreach ($propName in $obj.PSObject.Properties.Name) {
            if (-not $seen.ContainsKey($propName)) {
                $seen[$propName] = $true
                $allKeys.Add($propName)
            }
        }
    }

    $normalized = foreach ($obj in $flatObjects) {
        $row = [ordered]@{}
        foreach ($key in $allKeys) {
            if ($obj.PSObject.Properties.Name -contains $key) {
                $row[$key] = $obj.$key
            } else {
                $row[$key] = ""
            }
        }
        [PSCustomObject]$row
    }

    $normalized | Export-Csv -Path $Path -NoTypeInformation -Encoding UTF8
    Write-Log "Wrote $($normalized.Count) row(s) -> $Path" -Level SUCCESS
}

$RecordCounts = [ordered]@{}
$OverallStatus = "Success"

# ─── STAGE 1: PLATFORMS ───────────────────────────────────────────────────────────────────────
Write-Log "=== Fetching Platforms ===" -Level SECTION
$platformsRaw = @()
try {
    $platformsRaw = Get-PagedCollection -BaseUri "$PvwaBase/Platforms" -NoOffsetParams
    Write-Log "Total platforms fetched: $($platformsRaw.Count)" -Level SUCCESS
} catch {
    Write-Log "Platforms stage failed: $($_.Exception.Message)" -Level ERROR
    $OverallStatus = "PartialFailure"
}
Export-FlattenedCsv -Objects $platformsRaw -Path (Join-Path $LatestFolder "Platforms.csv")
$RecordCounts["Platforms"] = @($platformsRaw).Count

# ─── STAGE 2: SAFES ───────────────────────────────────────────────────────────────────────────
Write-Log "=== Fetching Safes ===" -Level SECTION
$safesRaw = @()
try {
    $safesRaw = Get-PagedCollection -BaseUri "$PvwaBase/Safes" -PageSize $PageSize
    Write-Log "Total safes fetched: $($safesRaw.Count)" -Level SUCCESS
} catch {
    Write-Log "Safes stage failed: $($_.Exception.Message)" -Level ERROR
    $OverallStatus = "PartialFailure"
}
Export-FlattenedCsv -Objects $safesRaw -Path (Join-Path $LatestFolder "Safes.csv")
$RecordCounts["Safes"] = @($safesRaw).Count

# ─── STAGE 3: SAFE MEMBERS ────────────────────────────────────────────────────────────────────
Write-Log "=== Fetching Safe Members ===" -Level SECTION
$safeMembersRaw = [System.Collections.Generic.List[object]]::new()
$safeIndex = 0
foreach ($safe in $safesRaw) {
    $safeIndex++
    $safeName = Get-FirstPropertyValue -Object $safe -CandidateNames @('safeName', 'SafeName')
    if (-not $safeName) { continue }

    if ($safeIndex % 100 -eq 0) {
        Write-Log "Safe members progress: $safeIndex / $($safesRaw.Count) safes processed" -Level INFO
    }

    # SafeName is a middle segment here (.../Safes/{name}/Members), so it's
    # just escaped directly - no trailing slash (see Get-SafeUrlSegment note).
    $urlSegment = [Uri]::EscapeDataString($safeName)
    $membersUri = "$PvwaBase/Safes/$urlSegment/Members?filter=includePredefinedUsers eq true"
    try {
        $members = Get-PagedCollection -BaseUri $membersUri -PageSize $PageSize
        foreach ($m in $members) {
            $flatMember = ConvertTo-FlatObject -InputObject $m
            $flatMember | Add-Member -NotePropertyName 'SafeName' -NotePropertyValue $safeName -Force
            $safeMembersRaw.Add($flatMember)
        }
    } catch {
        Write-Log "Failed to fetch members for safe '$safeName': $($_.Exception.Message)" -Level WARN
    }
}
Write-Log "Total safe member rows fetched: $($safeMembersRaw.Count)" -Level SUCCESS
Export-FlattenedCsv -Objects $safeMembersRaw -Path (Join-Path $LatestFolder "SafeMembers.csv")
$RecordCounts["SafeMembers"] = @($safeMembersRaw).Count

# ─── STAGE 4: ACCOUNTS ────────────────────────────────────────────────────────────────────────
Write-Log "=== Fetching Accounts ===" -Level SECTION
$accountsRaw = @()
try {
    $accountsRaw = Get-PagedCollection -BaseUri "$PvwaBase/Accounts" -PageSize $PageSize
    Write-Log "Total accounts fetched: $($accountsRaw.Count)" -Level SUCCESS
} catch {
    Write-Log "Accounts stage failed: $($_.Exception.Message)" -Level ERROR
    $OverallStatus = "PartialFailure"
}
Export-FlattenedCsv -Objects $accountsRaw -Path (Join-Path $LatestFolder "Accounts.csv")
$RecordCounts["Accounts"] = @($accountsRaw).Count

# ─── STAGE 5: ACCOUNT ACTIVITIES (usage) - full pull, one call per account ───────────────────
Write-Log "=== Fetching Account Activities (usage) for $($accountsRaw.Count) accounts ===" -Level SECTION
$activitiesRaw = [System.Collections.Generic.List[object]]::new()
$accountLastActivityUtc = @{}   # AccountID -> most recent activity [datetime] (UTC)
$acctIndex = 0
$activityFetchErrors = 0

foreach ($acct in $accountsRaw) {
    $acctIndex++
    $acctId       = Get-FirstPropertyValue -Object $acct -CandidateNames $AccountIdFields
    $acctName     = Get-FirstPropertyValue -Object $acct -CandidateNames $AccountNameFields
    $acctSafeName = Get-FirstPropertyValue -Object $acct -CandidateNames $AccountSafeNameFields
    $acctPlatform = Get-FirstPropertyValue -Object $acct -CandidateNames $AccountPlatformFields

    if (-not $acctId) {
        Write-Log "Account at index $acctIndex has no recognizable ID field (checked: $($AccountIdFields -join ', ')) - skipping activities lookup." -Level WARN
        continue
    }

    if ($acctIndex % 250 -eq 0 -or $acctIndex -eq $accountsRaw.Count) {
        Write-Log "Activities progress: $acctIndex / $($accountsRaw.Count) accounts processed" -Level INFO
    }
    Write-Progress -Activity "Fetching account activities" -Status "$acctIndex / $($accountsRaw.Count)" `
        -PercentComplete ([Math]::Min(100, [Math]::Floor(($acctIndex / [Math]::Max(1,$accountsRaw.Count)) * 100)))

    try {
        $activities = Get-PagedCollection -BaseUri "$PvwaBase/Accounts/$acctId/Activities" -NoOffsetParams
        foreach ($a in $activities) {
            $flatActivity = ConvertTo-FlatObject -InputObject $a
            $flatActivity | Add-Member -NotePropertyName 'AccountID'   -NotePropertyValue $acctId       -Force
            $flatActivity | Add-Member -NotePropertyName 'AccountName' -NotePropertyValue $acctName     -Force
            $flatActivity | Add-Member -NotePropertyName 'SafeName'    -NotePropertyValue $acctSafeName -Force
            $flatActivity | Add-Member -NotePropertyName 'PlatformID'  -NotePropertyValue $acctPlatform  -Force
            $activitiesRaw.Add($flatActivity)

            $rawDate = Get-FirstPropertyValue -Object $a -CandidateNames $ActivityDateFields
            if ($rawDate) {
                $parsed = $null
                if ([datetime]::TryParse($rawDate, [ref]$parsed)) {
                    $parsedUtc = $parsed.ToUniversalTime()
                    if (-not $accountLastActivityUtc.ContainsKey($acctId) -or $parsedUtc -gt $accountLastActivityUtc[$acctId]) {
                        $accountLastActivityUtc[$acctId] = $parsedUtc
                    }
                }
            }
        }
    } catch {
        $activityFetchErrors++
        Write-Log "Failed to fetch activities for account '$acctId' ($acctName): $($_.Exception.Message)" -Level WARN
    }
}
Write-Progress -Activity "Fetching account activities" -Completed
Write-Log "Total activity rows fetched: $($activitiesRaw.Count) (accounts with fetch errors: $activityFetchErrors)" -Level SUCCESS
Export-FlattenedCsv -Objects $activitiesRaw -Path (Join-Path $LatestFolder "AccountActivities.csv")
$RecordCounts["AccountActivities"] = @($activitiesRaw).Count

# ─── STAGE 6: LICENSE USAGE (best effort - NOT confirmed to exist on all tenants) ────────────
Write-Log "=== Fetching License Usage (best effort) ===" -Level SECTION
$licenseUsageRaw = @()
if ($LicenseUsageEndpoint) {
    try {
        $licResp = Invoke-ApiGet -Uri $LicenseUsageEndpoint
        if ($null -ne $licResp) {
            if ($licResp.PSObject.Properties.Name -contains 'value') {
                $licenseUsageRaw = @($licResp.value)
            } elseif ($licResp -is [System.Array]) {
                $licenseUsageRaw = @($licResp)
            } else {
                $licenseUsageRaw = @($licResp)
            }
            Write-Log "License usage rows fetched: $($licenseUsageRaw.Count)" -Level SUCCESS
        } else {
            Write-Log "License usage endpoint returned no data (see prior log line for HTTP status)." -Level WARN
        }
    } catch {
        Write-Log "License usage stage failed: $($_.Exception.Message)" -Level WARN
    }
} else {
    Write-Log "LicenseUsageEndpoint not configured - skipping. This report currently has no confirmed public REST API for component license capacity (CPM/PSM/PSMP/CCP); see script header NOTES." -Level WARN
}
Export-FlattenedCsv -Objects $licenseUsageRaw -Path (Join-Path $LatestFolder "LicenseUsage.csv")
$RecordCounts["LicenseUsage"] = @($licenseUsageRaw).Count

# ─── STAGE 7: SUMMARY (computed KPIs for Onboarded-vs-Used / Used-Account reports) ───────────
Write-Log "=== Computing Summary KPIs ===" -Level SECTION
$summaryRows = [System.Collections.Generic.List[object]]::new()
$nowUtc = (Get-Date).ToUniversalTime()

$totalOnboarded = @($accountsRaw).Count
$totalUsedEver  = $accountLastActivityUtc.Keys.Count

$summaryRows.Add([PSCustomObject]@{ Metric = "TotalPlatforms";        Value = @($platformsRaw).Count })
$summaryRows.Add([PSCustomObject]@{ Metric = "TotalSafes";            Value = @($safesRaw).Count })
$summaryRows.Add([PSCustomObject]@{ Metric = "TotalSafeMembers";      Value = @($safeMembersRaw).Count })
$summaryRows.Add([PSCustomObject]@{ Metric = "TotalOnboardedAccounts";Value = $totalOnboarded })
$summaryRows.Add([PSCustomObject]@{ Metric = "TotalAccountsUsedEver"; Value = $totalUsedEver })

foreach ($windowDays in $UsageWindowsDays) {
    $cutoffUtc = $nowUtc.AddDays(-1 * $windowDays)
    $usedInWindow = 0
    foreach ($lastActivity in $accountLastActivityUtc.Values) {
        if ($lastActivity -ge $cutoffUtc) { $usedInWindow++ }
    }
    $pct = 0
    if ($totalOnboarded -gt 0) { $pct = [Math]::Round(($usedInWindow / $totalOnboarded) * 100, 2) }

    $summaryRows.Add([PSCustomObject]@{ Metric = "AccountsUsedLast${windowDays}Days";     Value = $usedInWindow })
    $summaryRows.Add([PSCustomObject]@{ Metric = "AccountUsagePctLast${windowDays}Days";  Value = $pct })
}

Export-FlattenedCsv -Objects $summaryRows -Path (Join-Path $LatestFolder "Summary.csv")
$RecordCounts["SummaryMetrics"] = $summaryRows.Count

# ─── STAGE 8: MANIFEST + WRAP-UP ──────────────────────────────────────────────────────────────
$RunEndUtc = (Get-Date).ToUniversalTime()
if ($script:ErrorCount -gt 0 -and $OverallStatus -eq "Success") { $OverallStatus = "PartialFailure" }

$manifest = [ordered]@{
    RunTimestamp          = $RunStartUtc.ToString("o")
    RunCompletedTimestamp = $RunEndUtc.ToString("o")
    DurationSeconds        = [Math]::Round(($RunEndUtc - $RunStartUtc).TotalSeconds, 1)
    Status                 = $OverallStatus
    PSVersion               = $PSVersionTable.PSVersion.ToString()
    Counts                  = $RecordCounts
    Warnings                = $script:WarnCount
    Errors                  = $script:ErrorCount
    ArchivedPreviousRunTo   = $ArchivedTo
}
$manifest | ConvertTo-Json -Depth 5 | Set-Content -Path (Join-Path $LatestFolder "manifest.json") -Encoding UTF8

$Divider = "=" * 75
Write-Host ""
Write-Host $Divider -ForegroundColor White
Write-Host "  CYBERARK DASHBOARD DATA EXPORT - RUN SUMMARY" -ForegroundColor White
Write-Host $Divider -ForegroundColor White
Write-Host ("  Status              : {0}" -f $OverallStatus) -ForegroundColor $(if ($OverallStatus -eq "Success") { "Green" } else { "Yellow" })
Write-Host ("  Duration            : {0} sec" -f $manifest.DurationSeconds) -ForegroundColor White
Write-Host ("  Platforms           : {0}" -f $RecordCounts["Platforms"]) -ForegroundColor White
Write-Host ("  Safes               : {0}" -f $RecordCounts["Safes"]) -ForegroundColor White
Write-Host ("  Safe Members        : {0}" -f $RecordCounts["SafeMembers"]) -ForegroundColor White
Write-Host ("  Accounts            : {0}" -f $RecordCounts["Accounts"]) -ForegroundColor White
Write-Host ("  Account Activities  : {0}" -f $RecordCounts["AccountActivities"]) -ForegroundColor White
Write-Host ("  License Usage Rows  : {0}" -f $RecordCounts["LicenseUsage"]) -ForegroundColor White
Write-Host ("  Warnings / Errors   : {0} / {1}" -f $script:WarnCount, $script:ErrorCount) -ForegroundColor $(if ($script:ErrorCount -gt 0) { "Red" } else { "White" })
Write-Host ("  Output              : {0}" -f $LatestFolder) -ForegroundColor Green
Write-Host $Divider -ForegroundColor White

Write-Log "=== CyberArk Dashboard Data Export Complete (Status: $OverallStatus) ===" -Level SECTION

if ($OverallStatus -ne "Success") { exit 1 }
exit 0
