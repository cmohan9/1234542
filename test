#region ===== BLOCK 15 : SYSTEM HEALTH - SUMMARY ==========================
$HealthSummary = Invoke-RestMethod -Uri "$PvwaBase/ComponentsMonitoringSummary" -Method GET -Headers $Headers
$HealthSummary | ConvertTo-Json -Depth 10
#endregion

#region ===== BLOCK 16 : SYSTEM HEALTH - CPM DETAILS ======================
# HINT: change component id if needed. Valid: CPM, PVWA, PSM, PSMP, AIM
$ComponentId = "CPM"
