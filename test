# filename: pcloud-api-tester.ps1
# Code Generated by Sidekick is for learning and experimentation purposes only.

#region ===== BLOCK 0 : AUTH (RUN THIS FIRST) =============================
$IdentityTenantId  = "XXXXXXXXXXX"
$ServiceUserId     = "apiuser@XXXXXXXXXXXXX"
$ServiceUserSecret = "XXXXXXXXXXXXXX"
$Subdomain         = "XXXXXXXXXXX"

$IdentityUrl = "https://$IdentityTenantId.id.cyberark.cloud"
$PvwaBase    = "https://$Subdomain.privilegecloud.cyberark.cloud/PasswordVault/API"
$Limit       = 10   # small limit so terminal isn't flooded

$authBody = @{ grant_type="client_credentials"; client_id=$ServiceUserId; client_secret=$ServiceUserSecret }
$tokenResp = Invoke-RestMethod -Uri "$IdentityUrl/oauth2/platformtoken" -Method POST -Body $authBody -ContentType "application/x-www-form-urlencoded"
$Headers = @{ Authorization = "Bearer $($tokenResp.access_token)"; "Content-Type"="application/json" }
Write-Host "AUTH OK. Token acquired." -ForegroundColor Green
#endregion

#region ===== BLOCK 1 : SAFES (list) ======================================
$Safes = Invoke-RestMethod -Uri "$PvwaBase/Safes?limit=$Limit" -Method GET -Headers $Headers
Write-Host "Safes returned: $($Safes.value.Count)" -ForegroundColor Cyan
$Safes.value[0..1] | ConvertTo-Json -Depth 10
Write-Host "`n--- Candidate safeName values (copy one for Block 2/3) ---" -ForegroundColor Yellow
$Safes.value.safeName
#endregion

#region ===== BLOCK 2 : SAFE DETAILS ======================================
# HINT: paste a safeName from Block 1 output (e.g. "OCA-Win-Prod")
$FirstSafe = "PASTE_HERE"
$SafeDetail = Invoke-RestMethod -Uri "$PvwaBase/Safes/$FirstSafe" -Method GET -Headers $Headers
$SafeDetail | ConvertTo-Json -Depth 10
#endregion

#region ===== BLOCK 3 : SAFE MEMBERS ======================================
# HINT: paste a safeName from Block 1 output (same as Block 2, e.g. "OCA-Win-Prod")
$FirstSafe = "PASTE_HERE"
$SafeMembers = Invoke-RestMethod -Uri "$PvwaBase/Safes/$FirstSafe/Members?limit=$Limit" -Method GET -Headers $Headers
Write-Host "Members in '$FirstSafe': $($SafeMembers.value.Count)" -ForegroundColor Cyan
$SafeMembers.value | ConvertTo-Json -Depth 10
#endregion

#region ===== BLOCK 4 : USERS (list, extended) ============================
$Users = Invoke-RestMethod -Uri "$PvwaBase/Users?ExtendedDetails=True&limit=$Limit" -Method GET -Headers $Headers
Write-Host "Users returned: $($Users.Users.Count) (Total=$($Users.Total))" -ForegroundColor Cyan
$Users.Users[0..1] | ConvertTo-Json -Depth 10
Write-Host "`n--- Candidate id / username values (copy an id for Block 5) ---" -ForegroundColor Yellow
$Users.Users | Select-Object id, username | Format-Table -AutoSize
#endregion

#region ===== BLOCK 5 : USER DETAILS ======================================
# HINT: paste a numeric user 'id' from Block 4 output (e.g. 42) - NOT the username
$FirstUserId = "PASTE_HERE"
$UserDetail = Invoke-RestMethod -Uri "$PvwaBase/Users/$FirstUserId" -Method GET -Headers $Headers
$UserDetail | ConvertTo-Json -Depth 10
#endregion

#region ===== BLOCK 6 : USER GROUPS (list) ================================
$Groups = Invoke-RestMethod -Uri "$PvwaBase/UserGroups?limit=$Limit" -Method GET -Headers $Headers
Write-Host "Groups returned: $($Groups.value.Count)" -ForegroundColor Cyan
$Groups.value | ConvertTo-Json -Depth 10
#endregion

#region ===== BLOCK 7 : PLATFORMS (list) ==================================
$Platforms = Invoke-RestMethod -Uri "$PvwaBase/Platforms" -Method GET -Headers $Headers
Write-Host "Platforms returned: $($Platforms.Platforms.Count)" -ForegroundColor Cyan
$Platforms.Platforms[0..1] | ConvertTo-Json -Depth 10
Write-Host "`n--- Candidate platform IDs (copy one for Block 8) ---" -ForegroundColor Yellow
$Platforms.Platforms.general.id
#endregion

#region ===== BLOCK 8 : PLATFORM DETAILS ==================================
# HINT: paste a platform 'id' from Block 7 output (e.g. "WinServerLocal")
$FirstPlatformId = "PASTE_HERE"
$PlatformDetail = Invoke-RestMethod -Uri "$PvwaBase/Platforms/$FirstPlatformId" -Method GET -Headers $Headers
$PlatformDetail | ConvertTo-Json -Depth 10
#endregion

#region ===== BLOCK 9 : ACCOUNTS (list) ===================================
$Accounts = Invoke-RestMethod -Uri "$PvwaBase/Accounts?limit=$Limit" -Method GET -Headers $Headers
Write-Host "Accounts returned: $($Accounts.value.Count) (Total=$($Accounts.count))" -ForegroundColor Cyan
$Accounts.value[0..1] | ConvertTo-Json -Depth 10
Write-Host "`n--- Candidate account id / name values (copy an id for Blocks 11 & 12) ---" -ForegroundColor Yellow
$Accounts.value | Select-Object id, name, userName, safeName | Format-Table -AutoSize
#endregion

#region ===== BLOCK 10 : ACCOUNTS (filtered search example) ===============
# HINT: change 'admin' to any keyword (matches username/address/safe). Or use &filter=safeName eq YourSafe
