# ── STEP 5 : ACCOUNTS (star table) ───────────────────────────────────────────────
Write-Log "Collecting Accounts..." SECTION
$AcctRaw = Get-AllPaged -BaseUri "$PvwaBase/Accounts" -ValueProp "value"

# RAW (readable): flatten each fetched Account (incl. the secretManagement
# sub-object), epoch -> real dates.
$AcctRawOut = @(foreach($a in $AcctRaw){
    $sm = $a.secretManagement
    [pscustomobject]@{
        AccountID                  = $a.id
        Name                       = $a.name
        UserName                   = $a.userName
        Address                    = $a.address
        SafeName                   = $a.safeName
        PlatformID                 = $a.platformId
        SecretType                 = $a.secretType
        AutomaticManagementEnabled = $sm.automaticManagementEnabled
        ManualManagementReason     = $sm.manualManagementReason
        SecretStatus               = $sm.status
        LastModifiedTime           = Format-DateTime (ConvertFrom-Unix $sm.lastModifiedTime)
        LastVerifiedTime           = Format-DateTime (ConvertFrom-Unix $sm.lastVerifiedTime)
        LastReconciledTime         = Format-DateTime (ConvertFrom-Unix $sm.lastReconciledTime)
        CreatedTime                = Format-DateTime (ConvertFrom-Unix $a.createdTime)
        CategoryModificationTime   = Format-DateTime (ConvertFrom-Unix $a.categoryModificationTime)
    }
})
$AcctRawOut | Export-Csv "$OutputDir\Accounts_Raw.csv" -NoTypeInformation -Encoding UTF8

$AcctFact = @(foreach($a in $AcctRaw){
    $sfi = $SafeLookup[$a.safeName]
    $defSafe = if($sfi){$sfi.IsDefault}else{Test-IsDefaultSafe $a.safeName}
    $sm  = $a.secretManagement
    $auto= ($sm.automaticManagementEnabled -eq $true)
    $lastChg = ConvertFrom-Unix $sm.lastModifiedTime
    $lastVer = ConvertFrom-Unix $sm.lastVerifiedTime
    $created = ConvertFrom-Unix $a.createdTime
    $dChg = if($lastChg){(New-TimeSpan -Start $lastChg -End (Get-Date)).Days}else{$null}
    $dVer = if($lastVer){(New-TimeSpan -Start $lastVer -End (Get-Date)).Days}else{$null}
    $rot  = Get-RotationDays $a.platformId
    $comp = switch("$($sm.status)"){ "success"{"Compliant"} "failure"{"Non-Compliant"} default{"Pending/Unknown"} }

    [pscustomobject]@{
        AccountID       = $a.id
        UserName        = $a.userName
        Address         = $a.address
        SafeName        = $a.safeName
        IsDefaultSafe   = $defSafe
        Region          = if($sfi){$sfi.Region}else{Get-Region $a.safeName}
        Tier            = if($sfi){$sfi.Tier}else{Get-Tier $a.safeName}
        PlatformID      = $a.platformId
        OSCategory      = Get-OSCategory $a.platformId
        AutoManaged     = $auto
        MgmtTechnique   = if($auto){"Automatic (APM)"}else{"Manual (MPM)"}
        ManualReason    = $sm.manualManagementReason
        ComplianceStatus= $comp
        SecretStatus    = $sm.status
        LastChangeDate  = if($lastChg){$lastChg.ToString("yyyy-MM-dd")}else{""}
        DaysSinceChange = $dChg
        ExpectedRotationDays = $rot
        RotationOverdue = if($dChg -ne $null){ $dChg -gt $rot }else{$false}
        LastVerifyDate  = if($lastVer){$lastVer.ToString("yyyy-MM-dd")}else{""}
        DaysSinceVerify = $dVer
        VerifyStatus    = if(-not $auto){"N/A (Manual)"}
                          elseif(-not $lastVer){"Never Verified"}
                          elseif($dVer -gt $VerifyOverdueDays){"Overdue (> $VerifyOverdueDays d)"}
                          else{"OK"}
        IsStale         = if($dChg -ne $null){ $dChg -ge $StaleAccountDays }else{$false}
        CreatedDate     = if($created){$created.ToString("yyyy-MM-dd")}else{""}
        CreatedMonth    = if($created){$created.ToString("yyyy-MM")}else{""}
        RecentlyOnboarded = ($created -and (New-TimeSpan -Start $created -End (Get-Date)).Days -le $OnboardingWindowDays)
    }
})
$AcctFact | Export-Csv "$OutputDir\Accounts_Info.csv" -NoTypeInformation -Encoding UTF8
